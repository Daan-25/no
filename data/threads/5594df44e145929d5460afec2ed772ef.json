[{"id":"662166252ab049d4cf719e80c1b03678","from":"Meghan Naik","from_email":"naik@robinhood.org","to":"jeeproject@yahoo.com","to_list":[{"name":"jeeproject@yahoo.com","email":"jeeproject@yahoo.com"}],"cc_list":[{"name":"Rose Bromka","email":"bromka@robinhood.org"}],"subject":"Robin Hood Brochure Listing","date":"2016-08-18T18:30:10.000Z","formatted_date":"Aug 18, 2016","formatted_time":"6:30 PM","body":"Jeffrey,\n\nThank you for your incredible support of Robin Hood this past year and always.  We are in the process of preparing our annual brochure of generous Robin Hood supporters. Your current listing is Jeffrey Epstein. Kindly let me know if you prefer to be listed differently by August 22nd please.\n\nThis fall we have lined up a few exciting opportunities. Please see below and let me know if you'd like more information on any of these events.\n\nSeptember 26, 6:30pm -  Unplugged conversation about Robin Hood relief efforts and lessons learned\nOctober 19, 6:30pm - Unplugged conversation about mental health and learning needs of children\nOctober 21 - Robin Hood's Blue Ridge Labs fellows showcase their products\nNovember 15, 6:30pm - Unplugged conversation about Robin Hood's Poverty Tracker\nNovember 28 & 29, 8am - Robin Hood Investors Conference<http://investors.robinhood.org/>, gathering some of the brightest and most influential policy experts, hedge fund managers, tech innovators and more to share market insights and actionable, money-making ideas\n\nOn behalf of everyone here, but especially those families and individuals who benefit from your generosity, thank you for your commitment to Robin Hood!\n\nBest,\nMeghan\n\nMeghan Naik\n[cid:image001.png@01CE2ECD.E9E02F80]\n826 Broadway - 9th Floor\nNew York, NY 10003\n(212) 844-3568\n\n","body_html":"<html xmlns:v=\"urn:schemas-microsoft-com:vml\" xmlns:o=\"urn:schemas-microsoft-com:office:office\" xmlns:w=\"urn:schemas-microsoft-com:office:word\" xmlns:x=\"urn:schemas-microsoft-com:office:excel\" xmlns:m=\"http://schemas.microsoft.com/office/2004/12/omml\" xmlns=\"http://www.w3.org/TR/REC-html40\">\n<head>\n<meta http-equiv=\"Content-Type\" content=\"text/html; charset=us-ascii\">\n<meta name=\"Generator\" content=\"Microsoft Word 15 (filtered medium)\">\n<!--[if !mso]><style>v\\:* {behavior:url(#default#VML);}\no\\:* {behavior:url(#default#VML);}\nw\\:* {behavior:url(#default#VML);}\n.shape {behavior:url(#default#VML);}\n</style><![endif]--><style><!--\n/* Font Definitions */\n@font-face\n\t{font-family:\"Cambria Math\";\n\tpanose-1:2 4 5 3 5 4 6 3 2 4;}\n@font-face\n\t{font-family:\"Calibri Light\";\n\tpanose-1:2 15 3 2 2 2 4 3 2 4;}\n@font-face\n\t{font-family:Calibri;\n\tpanose-1:2 15 5 2 2 2 4 3 2 4;}\n/* Style Definitions */\np.MsoNormal, li.MsoNormal, div.MsoNormal\n\t{margin:0in;\n\tmargin-bottom:.0001pt;\n\tfont-size:11.0pt;\n\tfont-family:\"Calibri\",sans-serif;}\na:link, span.MsoHyperlink\n\t{mso-style-priority:99;\n\tcolor:#0563C1;\n\ttext-decoration:underline;}\na:visited, span.MsoHyperlinkFollowed\n\t{mso-style-priority:99;\n\tcolor:#954F72;\n\ttext-decoration:underline;}\nspan.EmailStyle17\n\t{mso-style-type:personal-compose;\n\tfont-family:\"Calibri\",sans-serif;\n\tcolor:windowtext;}\nspan.apple-converted-space\n\t{mso-style-name:apple-converted-space;}\n.MsoChpDefault\n\t{mso-style-type:export-only;\n\tfont-family:\"Calibri\",sans-serif;}\n@page WordSection1\n\t{size:8.5in 11.0in;\n\tmargin:1.0in 1.0in 1.0in 1.0in;}\ndiv.WordSection1\n\t{page:WordSection1;}\n--></style><!--[if gte mso 9]><xml>\n<o:shapedefaults v:ext=\"edit\" spidmax=\"1026\" />\n</xml><![endif]--><!--[if gte mso 9]><xml>\n<o:shapelayout v:ext=\"edit\">\n<o:idmap v:ext=\"edit\" data=\"1\" />\n</o:shapelayout></xml><![endif]-->\n</head>\n<body lang=\"EN-US\" link=\"#0563C1\" vlink=\"#954F72\">\n<div class=\"WordSection1\">\n<p class=\"MsoNormal\">Jeffrey,<o:p></o:p></p>\n<p class=\"MsoNormal\"><o:p>&nbsp;</o:p></p>\n<p class=\"MsoNormal\">Thank you for your incredible support of Robin Hood this past year and always.&nbsp; We are in the process of preparing our annual brochure of generous Robin Hood supporters. Your current listing is<b> Jeffrey Epstein.\n</b>Kindly let me know if you prefer to be listed differently by August 22<sup>nd\n</sup>please.<o:p></o:p></p>\n<p class=\"MsoNormal\">&nbsp;&nbsp;<o:p></o:p></p>\n<p class=\"MsoNormal\">This fall we have lined up a few exciting opportunities. Please see below and let me know if you&#8217;d like more information on any of these events.&nbsp;<span class=\"apple-converted-space\">&nbsp;</span><o:p></o:p></p>\n<p class=\"MsoNormal\"><b><o:p>&nbsp;</o:p></b></p>\n<p class=\"MsoNormal\"><b>September 26, 6:30pm<span class=\"apple-converted-space\">&nbsp;</span></b>&#8211;<span class=\"apple-converted-space\">&nbsp;</span><b>&nbsp;</b>Unplugged conversation about Robin Hood relief efforts and lessons learned<o:p></o:p></p>\n<p class=\"MsoNormal\"><b>October 19, 6:30pm</b><span class=\"apple-converted-space\">&nbsp;</span>&#8211; Unplugged conversation about mental health and learning needs of children<o:p></o:p></p>\n<p class=\"MsoNormal\"><b>October 21</b><span class=\"apple-converted-space\">&nbsp;</span>&#8211; Robin Hood&#8217;s Blue Ridge Labs fellows showcase their products<o:p></o:p></p>\n<p class=\"MsoNormal\"><b>November 15, 6:30pm</b><span class=\"apple-converted-space\">&nbsp;</span>&#8211;<span class=\"apple-converted-space\"><b>&nbsp;</b></span>Unplugged conversation about Robin Hood&#8217;s Poverty Tracker<br>\n<b>November 28 &amp; 29, 8am<span class=\"apple-converted-space\">&nbsp;</span></b>&#8211;<span class=\"apple-converted-space\">&nbsp;</span><a href=\"http://investors.robinhood.org/\"><span style=\"color:purple\">Robin Hood Investors Conference</span></a>, gathering some of the brightest\n and most influential policy experts, hedge fund managers, tech innovators and more to share market insights and actionable, money-making ideas<o:p></o:p></p>\n<p class=\"MsoNormal\"><o:p>&nbsp;</o:p></p>\n<p class=\"MsoNormal\">On behalf of everyone here, but especially those families and individuals who benefit from your generosity, thank you for your commitment to Robin Hood!<o:p></o:p></p>\n<p class=\"MsoNormal\">&nbsp;<o:p></o:p></p>\n<p class=\"MsoNormal\">Best,<o:p></o:p></p>\n<p class=\"MsoNormal\">Meghan<o:p></o:p></p>\n<p class=\"MsoNormal\"><o:p>&nbsp;</o:p></p>\n<p class=\"MsoNormal\"><b><span style=\"font-size:10.0pt;color:gray\">Meghan Naik<o:p></o:p></span></b></p>\n<p class=\"MsoNormal\"><img border=\"0\" width=\"134\" height=\"44\" style=\"width:1.3958in;height:.4583in\" id=\"Picture_x0020_1\" src=\"data:image/png;base64,\" alt=\"cid:image001.png@01CE2ECD.E9E02F80\"><o:p></o:p></p>\n<p class=\"MsoNormal\"><span style=\"font-size:10.0pt;font-family:&quot;Calibri Light&quot;,sans-serif;color:gray\">826 Broadway &#8211; 9<sup>th</sup> Floor<o:p></o:p></span></p>\n<p class=\"MsoNormal\"><span style=\"font-size:10.0pt;font-family:&quot;Calibri Light&quot;,sans-serif;color:gray\">New York, NY 10003<o:p></o:p></span></p>\n<p class=\"MsoNormal\"><span style=\"font-size:10.0pt;font-family:&quot;Calibri Light&quot;,sans-serif;color:gray\">(212) 844-3568<o:p></o:p></span></p>\n<p class=\"MsoNormal\"><o:p>&nbsp;</o:p></p>\n</div>\n</body>\n</html>\n","is_from_epstein":false,"attachments":1,"avatar_color":"#9c27b0","stars":17,"is_redacted":false}]