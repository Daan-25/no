te mso 9]><xml>\n <o:shapedefaults v:ext=\"edit\" spidmax=\"1026\" />\n</xml><![endif]--><!--[if gte mso 9]><xml>\n <o:shapelayout v:ext=\"edit\">\n  <o:idmap v:ext=\"edit\" data=\"1\" />\n </o:shapelayout></xml><![endif]-->\n</head>\n\n<body lang=EN-US link=blue vlink=purple>\n\n<div class=Section1>\n\n<p class=MsoNormal>I have given this to Darren. We have a meeting with DPNR\ntomorrow at 10 AM. I propose to submit a writing containing these arguments\nbacked by documents. I am inclined to eliminate references to other\ndevelopments by name at the end. Darren and I would both like your thoughts and\napproval. <o:p></o:p></p>\n\n</div>\n\n</body>\n\n</html>\n","is_from_epstein":false,"attachments":1,"avatar_color":"#db4437","stars":7,"is_redacted":false}]