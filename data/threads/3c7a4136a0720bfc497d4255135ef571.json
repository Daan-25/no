derline;}\nspan.EmailStyle17\n\t{font-family:\"Calibri\", \"sans-serif\";color:#1F497D;}\n.MsoChpDefault\n\t{font-size:10.0pt;}\n _filtered {margin:1.0in 1.0in 1.0in 1.0in;}\ndiv.Section1\n\t{}\n-->\n</STYLE>\n\n<DIV class=Section1>\n<P class=MsoNormal><SPAN style=\"FONT-SIZE: 11pt; COLOR: black; FONT-FAMILY: 'Calibri', 'sans-serif'\">The below list was picked up this week from 71<SUP>st</SUP> to go to Palm Beach.</SPAN></P>\n<P class=MsoNormal><SPAN style=\"FONT-SIZE: 11pt; COLOR: black; FONT-FAMILY: 'Calibri', 'sans-serif'\">&nbsp;</SPAN></P>\n<P class=MsoNormal><SPAN style=\"FONT-SIZE: 10pt; COLOR: black; FONT-FAMILY: 'Arial', 'sans-serif'\">We have 11 pieces of glass for desk tops </SPAN></P>\n<P class=MsoNormal><SPAN style=\"FONT-SIZE: 10pt; COLOR: black; FONT-FAMILY: 'Arial', 'sans-serif'\">Various pieces of metal for desks </SPAN></P>\n<P class=MsoNormal><SPAN style=\"FONT-SIZE: 10pt; COLOR: black; FONT-FAMILY: 'Arial', 'sans-serif'\">2 Black sculptures </SPAN></P>\n<P class=MsoNormal><SPAN style=\"FONT-SIZE: 10pt; COLOR: black; FONT-FAMILY: 'Arial', 'sans-serif'\">1 Hexagon Wooden table (Base &amp; Top) &nbsp;</SPAN></P>\n<P class=MsoNormal><SPAN style=\"FONT-SIZE: 11pt; COLOR: black; FONT-FAMILY: 'Calibri', 'sans-serif'\">&nbsp;</SPAN></P>\n<P class=MsoNormal><SPAN style=\"FONT-SIZE: 11pt; COLOR: black; FONT-FAMILY: 'Calibri', 'sans-serif'\">The couch from the 6<SUP>th</SUP> floor is scheduled to be picked up on the 12<SUP>th</SUP>.</SPAN></P>\n<P class=MsoNormal><SPAN style=\"FONT-SIZE: 11pt; COLOR: black; FONT-FAMILY: 'Calibri', 'sans-serif'\">&nbsp;</SPAN></P>\n<P class=MsoNormal><SPAN style=\"FONT-SIZE: 11pt; COLOR: black; FONT-FAMILY: 'Calibri', 'sans-serif'\">Should we wait for the couch and then send all the items or do you want these items to go now.</SPAN></P>\n<P class=MsoNormal><SPAN style=\"FONT-SIZE: 11pt; COLOR: black; FONT-FAMILY: 'Calibri', 'sans-serif'\">&nbsp;</SPAN></P>\n<P class=MsoNormal><SPAN style=\"FONT-SIZE: 11pt; COLOR: black; FONT-FAMILY: 'Calibri', 'sans-serif'\">Thank you</SPAN></P></DIV></DIV><BR></DIV></div></body></html>","is_from_epstein":true,"attachments":0,"avatar_color":"#9c27b0","stars":9,"is_redacted":false}]