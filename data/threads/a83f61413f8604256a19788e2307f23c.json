[{"id":"80c48f7a62c356f601eee1dee676edd2","from":"Lesley Groff","from_email":"lesley@nysgllc.com","to":"J. Epstein","to_list":[{"name":"J. Epstein","email":"jeeproject@yahoo.com"}],"cc_list":[],"subject":"FW: Best profile of Saul Griffith","date":"2007-09-27T19:18:02.000Z","formatted_date":"Sep 27, 2007","formatted_time":"7:18 PM","body":" \n\n \n\nFrom: David Grosof [mailto:grosof@sloan.mit.edu] \nSent: Thursday, September 27, 2007 3:17 PM\nTo: Lesley Groff\nSubject: Best profile of Saul Griffith\n\n \n\nHi, Lesley,\n\n Please print out for Jeffrey the profile of Saul Griffith at this\nwebpage:\nhttp://radar.oreilly.com/archives/2007/09/saul_griffith_macarthur.html \n\nTim O'Reilly, Dr. Griffith's future father-in-law,  writes about him\ninsightfully. O'Reilly is the guy behind O'Reilly Press and conferences\nsuch as Web 2.0.\n\nRegards,\nDavid\n\n","body_html":"<html xmlns:v=\"urn:schemas-microsoft-com:vml\" xmlns:o=\"urn:schemas-microsoft-com:office:office\" xmlns:w=\"urn:schemas-microsoft-com:office:word\" xmlns:m=\"http://schemas.microsoft.com/office/2004/12/omml\" xmlns=\"http://www.w3.org/TR/REC-html40\">\n\n<head>\n<META HTTP-EQUIV=\"Content-Type\" CONTENT=\"text/html; charset=us-ascii\">\n<meta name=Generator content=\"Microsoft Word 12 (filtered medium)\">\n<style>\n<!--\n /* Font Definitions */\n @font-face\n\t{font-family:Calibri;\n\tpanose-1:2 15 5 2 2 2 4 3 2 4;}\n@font-face\n\t{font-family:Tahoma;\n\tpanose-1:2 11 6 4 3 5 4 4 2 4;}\n /* Style Definitions */\n p.MsoNormal, li.MsoNormal, div.MsoNormal\n\t{margin:0in;\n\tmargin-bottom:.0001pt;\n\tfont-size:12.0pt;\n\tfont-family:\"Times New Roman\",\"serif\";}\na:link, span.MsoHyperlink\n\t{mso-style-priority:99;\n\tcolor:blue;\n\ttext-decoration:underline;}\na:visited, span.MsoHyperlinkFollowed\n\t{mso-style-priority:99;\n\tcolor:purple;\n\ttext-decoration:underline;}\nspan.EmailStyle17\n\t{mso-style-type:personal-reply;\n\tfont-family:\"Calibri\",\"sans-serif\";\n\tcolor:#1F497D;}\n.MsoChpDefault\n\t{mso-style-type:export-only;\n\tfont-size:10.0pt;}\n@page Section1\n\t{size:8.5in 11.0in;\n\tmargin:1.0in 1.0in 1.0in 1.0in;}\ndiv.Section1\n\t{page:Section1;}\n-->\n</style>\n<!--[if gte mso 9]><xml>\n <o:shapedefaults v:ext=\"edit\" spidmax=\"1026\" />\n</xml><![endif]--><!--[if gte mso 9]><xml>\n <o:shapelayout v:ext=\"edit\">\n  <o:idmap v:ext=\"edit\" data=\"1\" />\n </o:shapelayout></xml><![endif]-->\n</head>\n\n<body lang=EN-US link=blue vlink=purple>\n\n<div class=Section1>\n\n<p class=MsoNormal><span style='font-size:11.0pt;font-family:\"Calibri\",\"sans-serif\";\ncolor:#1F497D'><o:p>&nbsp;</o:p></span></p>\n\n<p class=MsoNormal><span style='font-size:11.0pt;font-family:\"Calibri\",\"sans-serif\";\ncolor:#1F497D'><o:p>&nbsp;</o:p></span></p>\n\n<div>\n\n<div style='border:none;border-top:solid #B5C4DF 1.0pt;padding:3.0pt 0in 0in 0in'>\n\n<p class=MsoNormal><b><span style='font-size:10.0pt;font-family:\"Tahoma\",\"sans-serif\"'>From:</span></b><span\nstyle='font-size:10.0pt;font-family:\"Tahoma\",\"sans-serif\"'> David Grosof\n[mailto:grosof@sloan.mit.edu] <br>\n<b>Sent:</b> Thursday, September 27, 2007 3:17 PM<br>\n<b>To:</b> Lesley Groff<br>\n<b>Subject:</b> Best profile of Saul Griffith<o:p></o:p></span></p>\n\n</div>\n\n</div>\n\n<p class=MsoNormal><o:p>&nbsp;</o:p></p>\n\n<p class=MsoNormal style='margin-bottom:12.0pt'>Hi, Lesley,<br>\n<br>\n&nbsp;Please print out for Jeffrey the profile of Saul Griffith at this webpage:<br>\n<a href=\"http://radar.oreilly.com/archives/2007/09/saul_griffith_macarthur.html\">http://radar.oreilly.com/archives/2007/09/saul_griffith_macarthur.html</a>\n<br>\n<br>\nTim O'Reilly, Dr. Griffith's future father-in-law,&nbsp; writes about him\ninsightfully. O'Reilly is the guy behind O'Reilly Press and conferences such as\nWeb 2.0.<br>\n<br>\nRegards,<br>\nDavid<o:p></o:p></p>\n\n</div>\n\n</body>\n\n</html>\n","is_from_epstein":false,"attachments":0,"avatar_color":"#0f9d58","stars":1,"is_redacted":false}]