[{"id":"f11f1284724b1a25ba30e14fb9af01c0","from":"Unknown","from_email":"CMi3540012@aol.com","to":"jeeproject@yahoo.com","to_list":[{"name":"jeeproject@yahoo.com","email":"jeeproject@yahoo.com"}],"cc_list":[{"name":"DKIESQ@aol.com","email":"DKIESQ@aol.com"},{"name":"CMi3540012@aol.com","email":"CMi3540012@aol.com"}],"subject":"Re: Utility Building Budget Estimate-Charles","date":"2008-03-05T15:59:50.000Z","formatted_date":"Mar 5, 2008","formatted_time":"3:59 PM","body":" \nJeffery, \nYour approval of budget estimate for Utility Building is  urgently required \nif we are not to jeopardize opportunity on favorable awards to  TSG for RO, \nNewman for concrete, and employment of a superintendent of  construction to \nassist Dan. \nMay I please have your approvals  for? \n    *   Utility Building Budget  estimate \n    *   Award of RO to TSG \n    *   Employment of construction superintendent to assist  Dan\nThank you, \nCharles \n__________________________________ \nAPPROVED\n\n\n\n**************It's Tax Time! Get tips, forms, and advice on AOL Money & \nFinance.      (http://money.aol.com/tax?NCID=aolprf00030000000001)\n","body_html":"<!DOCTYPE HTML PUBLIC \"-//W3C//DTD HTML 4.0 Transitional//EN\">\n<HTML xmlns:o = \"urn:schemas-microsoft-com:office:office\" xmlns:st1 = \n\"urn:schemas-microsoft-com:office:smarttags\"><HEAD>\n<META http-equiv=Content-Type content=\"text/html; charset=US-ASCII\">\n<META content=\"MSHTML 6.00.6000.16608\" name=GENERATOR></HEAD>\n<BODY id=role_body style=\"FONT-SIZE: 10pt; COLOR: #000000; FONT-FAMILY: Arial\" \nbottomMargin=7 leftMargin=7 topMargin=7 rightMargin=7><FONT id=role_document \nface=Arial color=#000000 size=2>\n<DIV>\n<P class=MsoNormal style=\"MARGIN: 0in 0in 0pt\"><B \nstyle=\"mso-bidi-font-weight: normal\"><FONT size=3><FONT \nface=\"Times New Roman\">Jeffery,<o:p></o:p></FONT></FONT></B></P>\n<P class=MsoNormal style=\"MARGIN: 0in 0in 0pt\"><B \nstyle=\"mso-bidi-font-weight: normal\"><o:p><FONT face=\"Times New Roman\" \nsi