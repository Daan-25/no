[{"id":"a12ad9f8454f7e19ef7d576abc1229a2","from":"Faculty of 1000 Biology","from_email":"info@f1000biology.com","to":"jeeproject@yahoo.com","to_list":[{"name":"jeeproject@yahoo.com","email":"jeeproject@yahoo.com"}],"cc_list":[],"subject":"Browse at your leisure, sip coffee with pleasure, and how we're made to measure!","date":"2008-07-11T16:17:17.000Z","formatted_date":"Jul 11, 2008","formatted_time":"4:17 PM","body":"Faculty of 1000 Biology Update\n\nYour email client does not support HTML emails or is not \nconfigured to view HTML emails.\n\nTo view the email in your web browser go to:\nhttp://www.f1000biology.com/about/press/update \n\n-----------------------------------------------------\n\nYou have received this message because you asked to \nreceive updates from Faculty of 1000 Biology.\n\nYour registered email address is: \njeeproject@yahoo.com\n\nTo unsubscribe send a blank email to: \nleave-2419959-100446683.6b811bde804de2323cb17b25bf5a9910@news.biomedcentral.com\n\nFor further information or enquiries please contact \nCustomer Services at: info@f1000biology.com\n\n-----------------------------------------------------\n\nScience Navigation Group, Middlesex House,\n34-42 Cleveland Street, London, W1T 4LB, United Kingdom\n\n","body_html":"<!DOCTYPE HTML PUBLIC \"-//W3C//Dtd HTML 4.01 Transitional//EN\"\n\"http://www.w3.org/TR/html4/loose.dtd\">\n<html>\n<head>\n<meta http-equiv=\"Content-Type\" content=\"text/html; charset=iso-8859-1\">\n<title>Faculty of 1000 Biology</title>\n\n<style type=\"text/css\">\n<!--\n\tbody {font-family:Verdana, Arial, Helvetica, sans-serif; font-size:13px; background-color:#FFFFFF}\n\ta {text-decoration: none; color:#333399}\n\ta:hover {text-decoration: underline}\n\th4 {color:#333399; font-size:16px} \n\timg {border:0; border-style:none}\n\t.bullet {margin-left:6px; margin-right:8px}\n.style1 {font-size: 10px}\n.style3 {font-size: 11px}\n-->\t\n\t\t\n</style>\n\n</head>\n\n<body bgcolor=\"#FFFFFF\" link=\"#333399\" vlink=\"#333399\" style=\"font-family:Verdana, Arial, Helvetica, sans-serif; font-size:13px\">\n<a name=\"top\"></a>\t\n<table width=\"595\" border=\"0\" align=\"center\">\n <tr>\n  <td width=\"100%\">\n\t<div style=\"text-align:left\">\n\t\n\t\t<p style=\"text-align:center; font-size:10px\">To view the email in your web browser go to: \n\t\t<a href=\"http://news.biomedcentral.com/t/2419959/100446683/234138/0/?u=aHR0cDovL3d3dy5mMTAwMGJpb2xvZ3kuY29tL2Fib3V0L3ByZXNzL3VwZGF0ZQ%3d%3d&x=55d66e94\">http://www.f1000biology.com/about/press/update</a></p>\n   \t<p align=\"right\">Friday 11 July 2008</p>\n\t\t<table width=\"600\" align=\"center\" cellpadding=\"0\" cellspacing=\"0\" bgcolor=\"#FFFFFF\">\n\t<tr>\n\t\t<td align=\"right\" height=\"10\" style=\"padding-right:4px;\" bgcolor=\"#FFFFFF\"><form action='http://www.f1000biology.com/search/results.asp' method='get' name='quicksearch' id=\"quicksearch\">Search F1000 Biology \n\t\t\t<input type='text' name='terms' size='50' class='compact' />&nbsp;<input name=\"image\" type='image' src='http://www.biomedcentral.com/graphics/buttons/greygo.gif' align='absmiddle' border='0' />\n\t\t\t\t<table cellpadding=\"0\" cellspacing=\"0\" width=\"10px\" align=\"center\" height=\"10px\">\n\t\t\t\t\t<tr>\n\t\t\t\t\t\t<td>&nbsp;</td>\n\t\t\t\t\t</tr>\n\t\t\t\t</table>\n\t\t\t\t</p>\n\t\t\t\t<input type=\"hidden\" name='area' value='f1000' checked=\"checked\" style='background : #D1DEDF' size=\"1\" />\n\t\t\t\t<input type='hidden' name='action' value='results' size=\"1\"/>\n\t\t\t\t</form>\t\t\t</td>\n\t\t </tr>\n\t\t</table>\n\t\t\t<div align=\"right\"><span class=\"style1\">Please note: The search function will not work for all email clients. \n\t\t\t<a href=\"http://news.biomedcentral.com/t/2419959/100446683/684416/0/?u=aHR0cDovL3d3dy5mMTAwMGJpb2xvZ3kuY29tL3NlYXJjaC9yZXN1bHRzLmFzcA%3d%3d&x=7f1d520e\">Click here to search F1000 Biology.</a>\t \t  </span>\t    </div>\n\t\t\t<hr />\n   <table width=\"100%\">\n   \t<tr> \t\n     \t<td width=\"350\" height=\"55\">\n\t\t\t\t<p><a href=\"http://news.biomedcentral.com/t/2419959/100446683/32013/0/?u=aHR0cDovL3d3dy5mMTAwMGJpb2xvZ3kuY29tLw%3d%3d&x=ce2b9d5d\"><img src=\"http://www.f1000biology.com/graphics/interface/header/9002/headsquare.gif\" alt=\"Faculty of 1000 Biology\" width=\"45\" height=\"45\" border=\"0\"></a> \n\t\t\t &nbsp;<a href=\"http://news.biomedcentral.com/t/2419959/100446683/32013/0/?u=aHR0cDovL3d3dy5mMTAwMGJpb2xvZ3kuY29tLw%3d%3d&x=ce2b9d5d\"><img src=\"http://www.f1000biology.com/graphics/interface/header/9002/type.gif\" alt=\"Faculty of 1000 Biology\" width=\"200\" height=\"45\" border=\"0\"></a>\n\t\t\t <a href=\"http://news.biomedcentral.com/t/2419959/100446683/32013/0/?u=aHR0cDovL3d3dy5mMTAwMGJpb2xvZ3kuY29tLw%3d%3d&x=ce2b9d5d\"><img src=\"http://www.f1000biology.com/graphics/interface/header/9002/strapline.gif\" alt=\"Faculty of 1000 Biology\" width=\"200\" height=\"14\" border=\"0\"></a></p>\t\t\t</td>\n     \t<td align=\"right\">\t\t\t \n\t\t\t\t<img src=\"http://www.biomedcentral.com/graphics/email/images/general/updatetxt.gif\" alt=\"\" width=\"98\" height=\"42\" border=0>  \t\t \t</td>\n    </tr>\n\t\t<tr>\n\t\t\t<td colspan=\"2\" align=\"center\">\n\t\t\t  <p style=\"color:#333399; font-size:16px; font-weight:bold\"><br>\n\t          <a href=\"http://news.biomedcentral.com/t/2419959/100446683/46076/0/?u=aHR0cDovL3d3dy5mMTAwMGJpb2xvZ3kuY29tL2Jyb3dzZS8%3d&x=be2ac0ca\">Major Advances. Expert Opinions.</a></p>\t\t    </td>\n\t\t</tr>\n   </table>\n  \t <p>\n\t     <strong>In this issue...</strong>    </p>\n  \t <table width=\"100%\" border=\"0\" cellspacing=\"3\" cellpadding=\"0\" style=\"font-weight:bold; font-size:13px\">\n       <tr>\n         <td width=\"6%\" valign=\"top\"><img src=\"http://www.biomedcentral.com/graphics/email/images/general/F100018x18_NEW.gif\" alt=\"\" width=\"18\" height=\"18\" class=\"bullet\" /></td>\n         <td width=\"94%\"><a href=\"#one\" class=\"style3\">F1000: Now free to explore!</a></td>\n       </tr>\n\t   <tr>\n         <td width=\"6%\" valign=\"top\"><img src=\"http://www.biomedcentral.com/graphics/email/images/general/F100018x18_NEW.gif\" alt=\"\" width=\"18\" height=\"18\" class=\"bullet\" /></td>\n         <td width=\"94%\"><a href=\"#two\" class=\"style3\">Faculty Members elected to the Royal Society and National Academy of Sciences</a></td>\n       </tr>\n\t   <tr>\n         <td width=\"6%\" valign=\"top\"><img src=\"http://www.biomedcentral.com/graphics/email/images/general/F100018x18_NEW.gif\" alt=\"\" width=\"18\" height=\"18\" class=\"bullet\" /></td>\n         <td width=\"94%\"><a href=\"#three\" class=\"style3\">Editor's choice: Choose caffeine, choose life!\n</a></td>\n       </tr>\n\t   <tr>\n         <td valign=\"top\"><img src=\"http://www.biomedcentral.com/graphics/email/images/general/F100018x18_NEW.gif\" alt=\"\" width=\"18\" height=\"18\" class=\"bullet\" /></td>\n         <td><a href=\"#four\" class=\"style3\">Hidden Jewel: Disease dynamics in chimpanzees</a></td>\n       </tr>\n       <tr>\n         <td valign=\"top\"><img src=\"http://www.biomedcentral.com/graphics/email/images/general/F100018x18_NEW.gif\" alt=\"\" width=\"18\" height=\"18\" class=\"bullet\" /></td>\n         <td><span class=\"style3\"><a href=\"#five\" class=\"style3\">Broad Impact: Weighing up the fa(c)ts</a></span></td>\n       </tr>\n       <tr>\n         <td valign=\"top\"><img src=\"http://www.biomedcentral.com/graphics/email/images/general/F100018x18_NEW.gif\" alt=\"\" width=\"18\" height=\"18\" class=\"bullet\" /></td>\n         <td><span class=\"style3\"><a href=\"#six\">Recommend F1000 to your librarian!</a></span></td>\n       </tr>\n\t   <tr>\n         <td valign=\"top\"><img src=\"http://www.biomedcentral.com/graphics/email/images/general/F100018x18_NEW.gif\" alt=\"\" width=\"18\" height=\"18\" class=\"bullet\" /></td>\n         <td><span class=\"style3\"><a href=\"#seven\">F1000 Biology posters</a></span></td>\n       </tr>\n     </table>\n  \t <p>\n\t <a name=\"one\"></a>\n     <hr>\n     <h4 style=\"font-size:16px\">F1000: Now free to explore!</h4>\n      <p align=\"left\"><a href=\"http://news.biomedcentral.com/t/2419959/100446683/32013/0/?u=aHR0cDovL3d3dy5mMTAwMGJpb2xvZ3kuY29tLw%3d%3d&x=ce2b9d5d\">F1000 Biology</a> and <a href=\"http://news.biomedcentral.com/t/2419959/100446683/63419/0/?u=aHR0cDovL3d3dy5mMTAwMG1lZGljaW5lLmNvbS8%3d&x=bc78e5b6\">F1000 Medicine</a>, the expert-driven article evaluation services, are now free for everybody to explore. You can browse through the extensive biomedical services to see which papers have been evaluated, as well as search for specific papers. This offers you the opportunity to get a flavor of the cr&egrave;me de la cr&egrave;me of the tens of thousands of selections archived in F1000 and to view the daily updates.</p>\n      <p align=\"left\">Designed to make sense of the vast and growing body of scholarly literature in the fields of biology and medicine, the award-winning online <a href=\"http://news.biomedcentral.com/t/2419959/100446683/1028226/0/?u=aHR0cDovL3d3dy5mMTAwMC5jb20v&x=371b16ea\">F1000 service</a> comprises over 4,500 of the world's most distinguished and respected researchers and clinicians who select key recent articles and evaluate them. This 'faculty of experts' thus highlights the cutting-edge articles that make a difference to biomedical scientists in their research and to clinicians in their every-day practice, saving everybody invaluable time by highlighting their significance. The articles are identified from over 2000 of the most highly regarded biomedical journals from a wide range of publishers, and they are then graded from an expert perspective.</p>\n      <p align=\"left\">If after browsing and searching you would like to view the full evaluations or to tailor the site to your specific preferences (i.e. set up MyF1000), then you can take advantage of F1000's <a href=\"http://news.biomedcentral.com/t/2419959/100446683/63238/0/?u=aHR0cDovL3d3dy5mMTAwMGJpb2xvZ3kuY29tL2Fib3V0L3RyaWFs&x=b51e0683\">3-week free trial</a>. Tell your friends!<br>\n      </p>\n      <p style=\"text-align:right; font-size:10px; padding-top:10px;\"><a href=\"#top\">back to top</a></p>\n      <a name=\"two\"></a>\n     <hr>\n     <h4 style=\"font-size:16px\">Faculty Members elected to the Royal Society and National Academy of Sciences</h4>\n      <div align=\"center\"><img src=\"http://www.biomedcentral.com/graphics/email/images/general/F1000B_17.07.07_Congratulations.jpg\" alt=\"\" width=\"485\" height=\"81\" border=\"0\" /></div>\n      <p align=\"left\"><strong>We would like to send our congratulations to the following F1000 Biology Faculty Members, who have recently been elected either as members of The National Academy of Sciences or as Fellows of the Royal Society.</strong></p>\n      <p align=\"left\"><strong>F1000 Faculty who are newly appointed members of The National Academy of Sciences, USA (May 2008)</strong></p>\n      <p align=\"left\"><a href=\"http://news.biomedcentral.com/t/2419959/100446683/1068227/0/?u=aHR0cDovL3d3dy5mMTAwMGJpb2xvZ3kuY29tL2Fib3V0L2Jpb2dyYXBoeS8xMDY3NjczODYxMjk2MTQ2&x=a65710f6\">Frances Arnold</a> (<a href=\"http://news.biomedcentral.com/t/2419959/100446683/705214/0/?u=aHR0cDovL3d3dy5mMTAwMGJpb2xvZ3kuY29tL2Fib3V0L21lbWJlcnMvODAyNw%3d%3d&x=99e5c8e7\">Chemical Biology</a> Faculty Member)<br>\n        <a href=\"http://news.biomedcentral.com/t/2419959/100446683/1068228/0/?u=aHR0cDovL3d3dy5mMTAwMGJpb2xvZ3kuY29tL2Fib3V0L2Jpb2dyYXBoeS8xMzM4Nzc0MTc2NTg1ODI0&x=d799c5bf\">Steven Boxer</a> (<a href=\"http://news.biomedcentral.com/t/2419959/100446683/705214/0/?u=aHR0cDovL3d3dy5mMTAwMGJpb2xvZ3kuY29tL2Fib3V0L21lbWJlcnMvODAyNw%3d%3d&x=99e5c8e7\">Chemical Biology</a> Faculty Member)<br>\n        <a href=\"http://news.biomedcentral.com/t/2419959/100446683/1068229/0/?u=aHR0cDovL3d3dy5mMTAwMGJpb2xvZ3kuY29tL2Fib3V0L2Jpb2dyYXBoeS85OTE2NDg2NTczMTc4MDY%3d&x=e804f791\">Caroline Dean</a> (<a href=\"http://news.biomedcentral.com/t/2419959/100446683/558217/0/?u=aHR0cDovL3d3dy5mMTAwMGJpb2xvZ3kuY29tL2Fib3V0L21lbWJlcnMvODAyOQ%3d%3d&x=4d52bf16\">Plant Biology</a> Section Head)<br>\n        <a href=\"http://news.biomedcentral.com/t/2419959/100446683/1068230/0/?u=aHR0cDovL3d3dy5mMTAwMGJpb2xvZ3kuY29tL2Fib3V0L2Jpb2dyYXBoeS82NTI1NjE5NzgzODQ2MjQ%3d&x=6336b6d1\">Margaret Fuller</a> (<a href=\"http://news.biomedcentral.com/t/2419959/100446683/507211/0/?u=aHR0cDovL3d3dy5mMTAwMGJpb2xvZ3kuY29tL2Fib3V0L21lbWJlcnMvODAwNg%3d%3d&x=035716fc\">Developmental Biology</a> Section Head)<br>\n        <a href=\"http://news.biomedcentral.com/t/2419959/100446683/1068231/0/?u=aHR0cDovL3d3dy5mMTAwMGJpb2xvZ3kuY29tL2Fib3V0L2Jpb2dyYXBoeS8zNjMyNTU4NDIzMTM1Mzk%3d&x=07edd4a4\">Jules Hoffman</a> (<a href=\"http://news.biomedcentral.com/t/2419959/100446683/561229/0/?u=aHR0cDovL3d3dy5mMTAwMGJpb2xvZ3kuY29tL2Fib3V0L21lbWJlcnMvODAyOA%3d%3d&x=181a37b9\">Immunology</a> Section Head)<br>\n        <a href=\"http://news.biomedcentral.com/t/2419959/100446683/1068232/0/?u=aHR0cDovL3d3dy5mMTAwMGJpb2xvZ3kuY29tL2Fib3V0L2Jpb2dyYXBoeS82ODQyODc0MzAzNTc1ODIy&x=9115d6b8\">David Mangelsdorf</a> (<a href=\"http://news.biomedcentral.com/t/2419959/100446683/322228/0/?u=aHR0cDovL3d3dy5mMTAwMGJpb2xvZ3kuY29tL2Fib3V0L21lbWJlcnMvODAyNg%3d%3d&x=ab32c582\">Cell Biology</a> Faculty Member)<br>\n        <a href=\"http://news.biomedcentral.com/t/2419959/100446683/1068233/0/?u=aHR0cDovL3d3dy5mMTAwMGJpb2xvZ3kuY29tL2Fib3V0L2Jpb2dyYXBoeS8xOTk0NzkwMTM2MzAwOTk1&x=02537d0d\">Anjana Rao</a> (<a href=\"http://news.biomedcentral.com/t/2419959/100446683/322228/0/?u=aHR0cDovL3d3dy5mMTAwMGJpb2xvZ3kuY29tL2Fib3V0L21lbWJlcnMvODAyNg%3d%3d&x=ab32c582\">Cell Biology</a> Faculty Member)<br>\n        <a href=\"http://news.biomedcentral.com/t/2419959/100446683/1068234/0/?u=aHR0cDovL3d3dy5mMTAwMGJpb2xvZ3kuY29tL2Fib3V0L2Jpb2dyYXBoeS8zNTAzMzQ3OTMxMTMzODAw&x=8bfaf2e3\">Johanna Schmitt</a>  (<a href=\"http://news.biomedcentral.com/t/2419959/100446683/641218/0/?u=aHR0cDovL3d3dy5mMTAwMGJpb2xvZ3kuY29tL2Fib3V0L21lbWJlcnMvODAzMg%3d%3d&x=9036acde\">Ecology</a> Faculty Member)</p>\n      <p align=\"left\"><strong>F1000 Faculty who are newly appointed Fellows of The Royal Society, UK (May 2008)</strong></p>\n      <p align=\"left\"><a href=\"http://news.biomedcentral.com/t/2419959/100446683/1068235/0/?u=aHR0cDovL3d3dy5mMTAwMGJpb2xvZ3kuY29tL2Fib3V0L2Jpb2dyYXBoeS80MzcyNDQwMTgzMDEwMzE%3d&x=c7302b00\">Stephen Jackson</a> (<a href=\"http://news.biomedcentral.com/t/2419959/100446683/322228/0/?u=aHR0cDovL3d3dy5mMTAwMGJpb2xvZ3kuY29tL2Fib3V0L21lbWJlcnMvODAyNg%3d%3d&x=ab32c582\">Cell Biology</a> Faculty Member)<br>\n        <a href=\"http://news.biomedcentral.com/t/2419959/100446683/1068236/0/?u=aHR0cDovL3d3dy5mMTAwMGJpb2xvZ3kuY29tL2Fib3V0L2Jpb2dyYXBoeS84MjM2OTYzNDEzODk0NjI%3d&x=8fa1ea06\">Claudio Stern</a> (<a href=\"http://news.biomedcentral.com/t/2419959/100446683/558211/0/?u=aHR0cDovL3d3dy5mMTAwMGJpb2xvZ3kuY29tL2Fib3V0L21lbWJlcnMvODAxNQ%3d%3d&x=b7b3ceb5\">Neuroscience</a> Faculty Member)<br>        \n        <br>\n        Congratulations from the F1000 editorial team!</p>\n      <p style=\"text-align:right; font-size:10px; padding-top:10px;\"><a href=\"#top\">back to top</a></p>\n      \n\t   <a name=\"three\"></a> </p>\n  \t <hr />\n  \t <h4><strong><a href=\"http://news.biomedcentral.com/t/2419959/100446683/1068237/0/?u=aHR0cDovL3d3dy5mMTAwMGJpb2xvZ3kuY29tL2FydGljbGUvaWQvMTExMzEwOQ%3d%3d&x=ecae50ad\">Editor's Choice: Choose caffeine, choose life!</a></strong></h4>\n     \n     <table width=\"100%\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\">\n\t <tr>\n         <td colspan=\"3\"><p>At last, a good reason to have that extra cup of coffee, other than to keep you awake at your desk! This month's Editor's Choice appeared in the Molecular Microbiology journal and highlights a study that found caffeine to increase lifespan in yeast by targeting the TORC1-Sch9-Rim15 phosphorylation cascade. As <a href=\"http://news.biomedcentral.com/t/2419959/100446683/561236/0/?u=aHR0cDovL3d3dy5mMTAwMGJpb2xvZ3kuY29tL2Fib3V0L2Jpb2dyYXBoeS8xODExMTc4NjcyMzA5Mzc5&x=d57aff85\">Ramon Serrano</a> and Jose M. Mulet of the <a href=\"http://news.biomedcentral.com/t/2419959/100446683/455219/0/?u=aHR0cDovL3d3dy5mMTAwMGJpb2xvZ3kuY29tL2Fib3V0L21lbWJlcnMvODAxMQ%3d%3d&x=bf8d3c46\">Microbiology</a> Faculty point out:\n           </p>\n           </td>\n       </tr>\n       <tr>\n         <td><p><a href=\"http://news.biomedcentral.com/t/2419959/100446683/1068237/0/?u=aHR0cDovL3d3dy5mMTAwMGJpb2xvZ3kuY29tL2FydGljbGUvaWQvMTExMzEwOQ%3d%3d&x=ecae50ad\">\"This important caffeine-(TORC1-Sch9-Rim15)-lifespan connection may be extended to humans because the protein kinase cascade is conserved in eukaryotes.\"</a> [see <a href=\"http://news.biomedcentral.com/t/2419959/100446683/1068237/0/?u=aHR0cDovL3d3dy5mMTAwMGJpb2xvZ3kuY29tL2FydGljbGUvaWQvMTExMzEwOQ%3d%3d&x=ecae50ad\">full evaluation</a>]</p>\n           <p>This study also serves to broaden our limited knowledge of the nutrient-sensitive mTOR complex.<br>\n             </p></td>\n\t\t\t<td width=\"10px\">&nbsp;\n            </td>\n         <td width=\"250px\"><a href=\"http://news.biomedcentral.com/t/2419959/100446683/1068237/0/?u=aHR0cDovL3d3dy5mMTAwMGJpb2xvZ3kuY29tL2FydGljbGUvaWQvMTExMzEwOQ%3d%3d&x=ecae50ad\"><img src=\"http://www.biomedcentral.com/graphics/email/images/general/F1000B_Update_July08_CoffeeBeans.jpg\" alt=\"Coffee Beans\" width=\"250\" height=\"163\" border=\"0\"></a></td>\n       </tr>\n     </table>\n     <div style=\"float:right; margin-top:7px; margin-right:2px; margin-left:8px\"></div>\n     <p style=\"text-align:right; font-size:10px; padding-top:10px;\"><a href=\"#top\">back to top</a></p>\n     <a name=\"four\"></a>\n      <hr>\n      <div style=\"float:left; margin-top:20px; margin-right:8px\"><span style=\"font-size:16px\"><img src=\"http://www.biomedcentral.com/graphics/email/images/general/F1000B_Update_HiddenJewel.gif\" alt=\"\" width=\"29\" height=\"30\" border=\"0\" /></span></div>\n      <h4 style=\"font-size:16px\"><a href=\"http://news.biomedcentral.com/t/2419959/100446683/1068238/0/?u=aHR0cDovL3d3dy5mMTAwMGJpb2xvZ3kuY29tL2FydGljbGUvaWQvMTExNjI4Mg%3d%3d&x=8c6d57e1\">Hidden Jewel: Disease dynamics in chimpanzees</a></h4>\n      <p>This paper, evaluated by <a href=\"http://news.biomedcentral.com/t/2419959/100446683/841252/0/?u=aHR0cDovL3d3dy5mMTAwMGJpb2xvZ3kuY29tL2Fib3V0L2Jpb2dyYXBoeS82NzYwNDIwMDIzMTQwNDE1&x=b5259bad\">Niyaz Ahmed</a> of the <a href=\"http://news.biomedcentral.com/t/2419959/100446683/455219/0/?u=aHR0cDovL3d3dy5mMTAwMGJpb2xvZ3kuY29tL2Fib3V0L21lbWJlcnMvODAxMQ%3d%3d&x=bf8d3c46\">Microbiology</a> Faculty , looks at infant mortality cycles in chimpanzees.</p>\n      <p>Niyaz explains that, <a href=\"http://news.biomedcentral.com/t/2419959/100446683/1068238/0/?u=aHR0cDovL3d3dy5mMTAwMGJpb2xvZ3kuY29tL2FydGljbGUvaWQvMTExNjI4Mg%3d%3d&x=8c6d57e1\">\"This study elegantly reveals the role of chimpanzee's infant offspring in the spread of infection to the rest of their family.\"</a> and comments that it <a href=\"http://news.biomedcentral.com/t/2419959/100446683/1068238/0/?u=aHR0cDovL3d3dy5mMTAwMGJpb2xvZ3kuY29tL2FydGljbGUvaWQvMTExNjI4Mg%3d%3d&x=8c6d57e1\">\"...has wider conservation implications and it is being discussed in the media and blogosphere.\"</a> [see <a href=\"http://news.biomedcentral.com/t/2419959/100446683/1068238/0/?u=aHR0cDovL3d3dy5mMTAwMGJpb2xvZ3kuY29tL2FydGljbGUvaWQvMTExNjI4Mg%3d%3d&x=8c6d57e1\">full evaluation</a>]</p>\n      <p><a href=\"http://news.biomedcentral.com/t/2419959/100446683/196212/0/?u=aHR0cDovL3d3dy5mMTAwMGJpb2xvZ3kuY29tL3RvcDEwL2pld2Vscy8%3d&x=5ad94f7b\">The Hidden Jewels lists</a> are one of the most popular features on the Faculty of  1000 Biology site as they bring to scientists' attention papers they otherwise  might have missed (especially in fields adjacent to their own). This list is  compiled daily and includes highly viewed papers evaluated within the previous  month.\t  </p>\n      <p style=\"text-align:right; font-size:10px; padding-top:10px;\"><a href=\"#top\">back to top</a></p>\n\t <a name=\"five\"></a>\n     <hr />\n    \n     <div style=\"float:left; margin-top:20px; margin-right:8px\"><img src=\"http://www.biomedcentral.com/graphics/email/images/general/F1000B_Update_Ripple.gif\" alt=\"\" width=\"30\" height=\"30\" border=\"0\" /> </div>\n     <h4><a href=\"http://news.biomedcentral.com/t/2419959/100446683/1068239/0/?u=aHR0cDovL3d3dy5mMTAwMGJpb2xvZ3kuY29tL2FydGljbGUvaWQvMTEwOTQ0Mw%3d%3d&x=6571b9e2\">Broad Impact: Weighing up the fa(c)ts</a> </h4>\n     <p>Embarking on another summer slimming regime? In this month's Broad Impact paper, researchers from Sweden's Karolinska Institute have shown that weight loss doesn't necessarily equal fat loss, as fat cell numbers appear to remain stable throughout one's life, regardless of body weight. These findings and their widespread implications have triggered the interest of many Faculty Members, including those from the Pharmacology &amp; Drug Discovery, Developmental Biology and Physiology Faculties.</p>\n     <table width=\"100%\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\">\n       <tr>\n         <td><p><a href=\"http://news.biomedcentral.com/t/2419959/100446683/1068240/0/?u=aHR0cDovL3d3dy5mMTAwMGJpb2xvZ3kuY29tL2Fib3V0L2Jpb2dyYXBoeS81NDUzNTI2NDgxNTA2MDM4&x=3d239ce3\">Michele Forman</a>, a <a href=\"http://news.biomedcentral.com/t/2419959/100446683/234095/0/?u=aHR0cDovL3d3dy5mMTAwMGJpb2xvZ3kuY29tL2Fib3V0L21lbWJlcnMvODAzNA%3d%3d&x=3e023fa3\">Pharmacology &amp; Drug Discovery</a> Faculty Member, notes that <a href=\"http://news.biomedcentral.com/t/2419959/100446683/1068239/0/?u=aHR0cDovL3d3dy5mMTAwMGJpb2xvZ3kuY29tL2FydGljbGUvaWQvMTEwOTQ0Mw%3d%3d&x=6571b9e2\">&quot;This is the first paper to report that the number of fat cells stays constant in adulthood in lean and obese individuals, even after marked weight loss, indicating that the number of adipocytes is set during childhood and adolescence.&quot;</a></p>\n            <p><a href=\"http://news.biomedcentral.com/t/2419959/100446683/1068241/0/?u=aHR0cDovL3d3dy5mMTAwMGJpb2xvZ3kuY29tL2Fib3V0L2Jpb2dyYXBoeS8xOTg3MDYyODc4MzAxMDcy&x=288378f3\">Anthony Means</a>  of the <a href=\"http://news.biomedcentral.com/t/2419959/100446683/322228/0/?u=aHR0cDovL3d3dy5mMTAwMGJpb2xvZ3kuY29tL2Fib3V0L21lbWJlcnMvODAyNg%3d%3d&x=ab32c582\">Cell Biology</a>  Faculty describes the technique employed by the authors as a <a href=\"http://news.biomedcentral.com/t/2419959/100446683/1068239/0/?u=aHR0cDovL3d3dy5mMTAwMGJpb2xvZ3kuY29tL2FydGljbGUvaWQvMTEwOTQ0Mw%3d%3d&x=6571b9e2\">&quot;a clever form of C14 dating&quot;</a>, which is used to <a href=\"http://news.biomedcentral.com/t/2419959/100446683/1068239/0/?u=aHR0cDovL3d3dy5mMTAwMGJpb2xvZ3kuY29tL2FydGljbGUvaWQvMTEwOTQ0Mw%3d%3d&x=6571b9e2\">&quot;assess adipocyte turnover.&quot;</a></p>\n            <p><a href=\"http://news.biomedcentral.com/t/2419959/100446683/507211/0/?u=aHR0cDovL3d3dy5mMTAwMGJpb2xvZ3kuY29tL2Fib3V0L21lbWJlcnMvODAwNg%3d%3d&x=035716fc\">Developmental Biologist</a> <a href=\"http://news.biomedcentral.com/t/2419959/100446683/1068242/0/?u=aHR0cDovL3d3dy5mMTAwMGJpb2xvZ3kuY29tL2Fib3V0L2Jpb2dyYXBoeS8xOTU4MzA0OTAzMzA1ODgx&x=c1eae189\">Jonathan Slack</a>  goes on to comment that adipocyte turnover rates were found to be <a href=\"http://news.biomedcentral.com/t/2419959/100446683/1068239/0/?u=aHR0cDovL3d3dy5mMTAwMGJpb2xvZ3kuY29tL2FydGljbGUvaWQvMTEwOTQ0Mw%3d%3d&x=6571b9e2\">&quot;the same in lean and obese individuals, who differ not only in adipose cell size but also in adipose cell numbers established during childhood.&quot;</a><br>\n             </p>\n            </td>\n         <td width=\"10px\">&nbsp;</td>\n         <td width=\"186px\"><a href=\"http://news.biomedcentral.com/t/2419959/100446683/1068239/0/?u=aHR0cDovL3d3dy5mMTAwMGJpb2xvZ3kuY29tL2FydGljbGUvaWQvMTEwOTQ0Mw%3d%3d&x=6571b9e2\"><img src=\"http://www.biomedcentral.com/graphics/email/images/general/F1000B_Update_July08_Weight.jpg\" alt=\"Weighing up the fa(c)ts\" width=\"186\" height=\"250\" border=\"0\"></a></td>\n       </tr>\n     </table>\n     <p>It's not all bad news though, as <a href=\"http://news.biomedcentral.com/t/2419959/100446683/1068243/0/?u=aHR0cDovL3d3dy5mMTAwMGJpb2xvZ3kuY29tL2Fib3V0L2Jpb2dyYXBoeS85NTk2OTUxMTcyNjUyMjEz&x=55d04223\">William College</a> of the <a href=\"http://news.biomedcentral.com/t/2419959/100446683/234144/0/?u=aHR0cDovL3d3dy5mMTAwMGJpb2xvZ3kuY29tL2Fib3V0L21lbWJlcnMvODAwOQ%3d%3d&x=bf98ec09\">Genomics and Genetics</a> Faculty highlights the potential for a <a href=\"http://news.biomedcentral.com/t/2419959/100446683/1068239/0/?u=aHR0cDovL3d3dy5mMTAwMGJpb2xvZ3kuY29tL2FydGljbGUvaWQvMTEwOTQ0Mw%3d%3d&x=6571b9e2\">&quot;new therapeutic target to combat obesity&quot;</a> as a result of these findings.</p>\n     <p>To wrap things up, <a href=\"http://news.biomedcentral.com/t/2419959/100446683/455217/0/?u=aHR0cDovL3d3dy5mMTAwMGJpb2xvZ3kuY29tL2Fib3V0L21lbWJlcnMvODAzMw%3d%3d&x=df7b6baa\">Physiologist</a> <a href=\"http://news.biomedcentral.com/t/2419959/100446683/1068244/0/?u=aHR0cDovL3d3dy5mMTAwMGJpb2xvZ3kuY29tL2Fib3V0L2Jpb2dyYXBoeS8xMjc4NDM1NDg2Mjk2NzY5&x=8b4a4af7\">Michael Symonds</a> sets the scene for future work, by predicting that <a href=\"http://news.biomedcentral.com/t/2419959/100446683/1068239/0/?u=aHR0cDovL3d3dy5mMTAwMGJpb2xvZ3kuY29tL2FydGljbGUvaWQvMTEwOTQ0Mw%3d%3d&x=6571b9e2\">&quot;there will now be tremendous interest in the regulation of fat cell number and how this may be set very early in life.&quot;</a></p>\n     <p>The <a href=\"http://news.biomedcentral.com/t/2419959/100446683/234145/0/?u=aHR0cDovL3d3dy5mMTAwMGJpb2xvZ3kuY29tL2Fib3V0L2hvdw%3d%3d&x=dddf06b5\">Faculty of 1000 Biology structure</a> makes it possible to identify papers of broad interest, irrespective of the journal in which they are published. You can see the <a href=\"http://news.biomedcentral.com/t/2419959/100446683/1068239/0/?u=aHR0cDovL3d3dy5mMTAwMGJpb2xvZ3kuY29tL2FydGljbGUvaWQvMTEwOTQ0Mw%3d%3d&x=6571b9e2\">full comments</a> of all the evaluating Faculty Members on this Exceptional Broad Impact paper by visiting the Faculty of 1000 Biology website.     </p>\n     <p style=\"text-align:right; font-size:10px; padding-top:10px;\"><a href=\"#top\">back to top</a></p>\n      <a name=\"six\"></a>\n\t         <hr />\n   \t         <h4>Does your institute currently have access to F1000 Biology? If not, why not recommend to your librarian!</h4>\n   \t         <p>Over 90% of the world's top institutions currently subscribe to F1000 Biology and many more are trialling. Why not <a href=\"http://news.biomedcentral.com/t/2419959/100446683/32013/0/?u=aHR0cDovL3d3dy5mMTAwMGJpb2xvZ3kuY29tLw%3d%3d&x=ce2b9d5d\">visit the site</a> to see if your own institute has access.</p>\n   \t         <p>If your institution does  not have access, then please recommend the service to your library or  institution so that they can arrange a free 30-day trial.</p>\n   \t         <p>You can use our <a href=\"http://news.biomedcentral.com/t/2419959/100446683/95052/0/?u=aHR0cDovL3d3dy5mMTAwMGJpb2xvZ3kuY29tL2Fib3V0L2luc3RpdHV0aW9uL2FjYWRlbWljL3JlY29tbWVuZA%3d%3d&x=b03b7aa3\">online form</a> to send your recommendation. If you prefer, there is a <a href=\"http://news.biomedcentral.com/t/2419959/100446683/829214/0/?u=aHR0cDovL3d3dy5mMTAwMGJpb2xvZ3kuY29tL2Jpb2xvZ3kvZG93bmxvYWQvcmVxdWVzdC5wZGY%3d&x=b070cfb1\">printable form</a> (PDF). </p>\n   \t         <p>Alternatively, you may qualify for free access via HINARI or Faculty Member sponsorships: see <a href=\"http://news.biomedcentral.com/t/2419959/100446683/234149/0/?u=aHR0cDovL3d3dy5mMTAwMGJpb2xvZ3kuY29tL2Fib3V0L2hpbmFyaQ%3d%3d&x=53b81315\">http://www.f1000biology.com/about/hinari</a>.</p>\n        <p style=\"text-align:right; font-size:10px; padding-top:10px;\"><a href=\"#top\">back to top</a>\t </p>\n\n\t  \n      <a name=\"seven\"></a>\n     <hr />\n     \n\t <p></p>\n\t <h4 style=\"font-size:16px\">Request some Faculty of 1000 Biology posters</h4>\n\t <p>We have 4 poster designs! If you would like to receive your copy of each design to let your friends and colleagues know about Faculty of 1000 Biology, email us at <a href=\"mailto:info@f1000biology.com?subject=Please send me my copies of the 4 new F1000 Biology posters\">info@f1000biology.com</a>  with your full postal address. <br>\n\t </p>\n\t <table width=\"98%\" align=\"center\">\n       <tr>\n         <td><a href=\"mailto:info@f1000biology.com?subject=Please send me my copies of the 4 new F1000 Biology posters\"><img src=\"http://www.biomedcentral.com/graphics/email/images/general/f1000biology-poster-iceberg.jpg\" alt=\"New Faculty of 1000 Biology poster\" width=\"130\" height=\"183\" border=\"0\"></a></td>\n         <td><a href=\"mailto:info@f1000biology.com?subject=Please send me my copies of the 4 new F1000 Biology posters\"><img src=\"http://www.biomedcentral.com/graphics/email/images/general/f1000biology-poster-net.jpg\" alt=\"New Faculty of 1000 Biology poster\" width=\"130\" height=\"183\" border=\"0\"></a></td>\n         <td><a href=\"mailto:info@f1000biology.com?subject=Please send me my copies of the 4 new F1000 Biology posters\"><img src=\"http://www.biomedcentral.com/graphics/email/images/general/f1000biology-poster-lighthouse.jpg\" alt=\"New Faculty of 1000 Biology poster\" width=\"130\" height=\"183\" border=\"0\"></a></td>\n         <td><a href=\"mailto:info@f1000biology.com?subject=Please send me my copies of the 4 new F1000 Biology posters\"><img src=\"http://www.biomedcentral.com/graphics/email/images/general/f1000biology-poster-screens.jpg\" alt=\"New Faculty of 1000 Biology poster\" width=\"130\" height=\"183\" border=\"0\"></a></td>\n       </tr>\n       <tr>\n         <td height=\"8px\" colspan=\"4\"></td>\n       </tr>\n     </table>\n\t <p>If you are at a non-subscribing institute and would like to let your friends and colleagues know about our Free 7 Day Trial, simply email us at <a href=\"mailto:info@f1000biology.com?subject=Please%20send%20me%20an%20F1000%20Biology%20poster\">info@f1000biology.com</a> with your full postal address and which poster you would like (i.e. Italian, German, Japanese or English). <br>\n</p>\n\t <table width=\"98%\" align=\"center\">\n       <tr>\n         <td><a href=\"mailto:info@f1000biology.com?subject=Please send me an F1000 Biology poster\"><img src=\"http://www.biomedcentral.com/graphics/email/images/general/f1000biology-poster-italian.gif\" alt=\"Italian poster\" width=\"130\" height=\"158\" border=\"0\"></a></td>\n         <td><a href=\"mailto:info@f1000biology.com?subject=Please send me an F1000 Biology poster\"><img src=\"http://www.biomedcentral.com/graphics/email/images/general/f1000biology-poster-german.gif\" alt=\"German poster\" width=\"130\" height=\"158\" border=\"0\"></a></td>\n         <td><a href=\"mailto:info@f1000biology.com?subject=Please send me an F1000 Biology poster\"><img src=\"http://www.biomedcentral.com/graphics/email/images/general/f1000biology-poster-japanese.gif\" alt=\"Japanese poster\" width=\"130\" height=\"158\" border=\"0\"></a></td>\n         <td><a href=\"mailto:info@f1000biology.com?subject=Please send me an F1000 Biology poster\"><img src=\"http://www.biomedcentral.com/graphics/email/images/general/f1000biology-poster-english.gif\" alt=\"English poster\" width=\"130\" height=\"158\" border=\"0\"></a></td>\n       </tr>\n     </table>\n\t <p style=\"text-align:right; font-size:10px; padding-top:10px;\"><a href=\"#top\">back to top</a></p>\n\t\n\t\t\t\t <hr />\n\t <p style=\"text-align:center; font-size:10px\">You have received this message because you asked to receive updates from Faculty of 1000 Biology.<br />\n\t\t\tYour registered email address is: jeeproject@yahoo.com<br />\n\t\t\tTo unsubscribe send a blank email to: <a href=\"mailto:leave-2419959-100446683.6b811bde804de2323cb17b25bf5a9910@news.biomedcentral.com\">leave-2419959-100446683.6b811bde804de2323cb17b25bf5a9910@news.biomedcentral.com</a><br />\n   \t\tFor further information or enquiries please contact Customer Services at: \n\t\t\t<a href=\"mailto:info@f1000biology.com\">info@f1000biology.com</a>\t </p>\n\t \n\t <hr />\n\t <p style=\"text-align:center; font-size:10px\"><span class=\"style1\">F1000 Biology, Biology Reports Ltd<br>\nScience Navigation Group, Middlesex House, 34-42 Cleveland Street, London, W1T 4LB, United Kingdom</span></p>\n\t</div> \t</td>\n </tr>\n</table>\n<IMG ALT=\"\" SRC=\"http://news.biomedcentral.com/db/2419959/100446683/1.gif\" WIDTH=1 HEIGHT=1></body>\n</html>\n","is_from_epstein":false,"attachments":0,"avatar_color":"#f39c12","stars":1,"is_redacted":false}]