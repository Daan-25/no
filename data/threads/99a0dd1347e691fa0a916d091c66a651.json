[{"id":"e4affcf37a6a084640318622ccb210b7","from":"J. Epstein","from_email":"jeeproject@yahoo.com","to":"Lesley Groff","to_list":[{"name":"Lesley Groff","email":"lesley@nysgllc.com"}],"cc_list":[],"subject":"Re:","date":"2007-09-19T23:13:55.000Z","formatted_date":"Sep 19, 2007","formatted_time":"11:13 PM","body":"ok spanky\n\n\n----- Original Message ----\nFrom: Lesley Groff <lesley@nysgllc.com>\nTo: J. Epstein <jeeproject@yahoo.com>\nSent: Wednesday, September 19, 2007 8:39:11 AM\nSubject: FW:\n\n\n \n \nFrom: Steve Tuckerman [mailto:steve@tuckermandevelopment.com] \nSent: Tuesday, September 18, 2007 10:33 PM\nTo: Lesley Groff\nSubject: \n \nDear Jeffery,\n \nI understand that things have not been going to well. Judy and I just wanted you to know that our thoughts and love are with you at all times.\n \nIf there is anything we can do for you at any time, please let us know. \n \nWe will always be there for you.\n \nLove,\n \nSteve and Judy","body_html":"<html><head><style type=\"text/css\"><!-- DIV {margin:0px;} --></style></head><body><div style=\"font-family:times new roman, new york, times, serif;font-size:12pt\"><DIV style=\"FONT-SIZE: 12pt; FONT-FAMILY: times new roman, new york, times, serif\">ok spanky<BR><BR>\n<DIV style=\"FONT-SIZE: 12pt; FONT-FAMILY: times new roman, new york, times, serif\">----- Original Message ----<BR>From: Lesley Groff &lt;lesley@nysgllc.com&gt;<BR>To: J. Epstein &lt;jeeproject@yahoo.com&gt;<BR>Sent: Wednesday, September 19, 2007 8:39:11 AM<BR>Subject: FW:<BR><BR>\n<STYLE>\n<!--\n _filtered {font-family:Calibri;panose-1:2 15 5 2 2 2 4 3 2 4;}\n _filtered {font-family:Tahoma;panose-1:2 11 6 4 3 5 4 4 2 4;}\n/* Style Definitions */\n p.MsoNormal, li.MsoNormal, div.MsoNormal\n\t{margin:0in;margin-bottom:.0001pt;font-size:12.0pt;font-family:\"Times New Roman\", \"serif\";}\na:link, span.MsoHyperlink\n\t{color:blue;text-decoration:underline;}\na:visited, span.MsoHyperlinkFollowed\n\t{color:purple;text-decoration:underline;}\nspan.EmailStyl