rmal><SPAN style=\"FONT-SIZE: 10pt; FONT-FAMILY: 'Arial', 'sans-serif'\">We will always be there for you.</SPAN></P>\n<P class=MsoNormal><SPAN style=\"FONT-SIZE: 10pt; FONT-FAMILY: 'Arial', 'sans-serif'\">&nbsp;</SPAN></P>\n<P class=MsoNormal><SPAN style=\"FONT-SIZE: 10pt; FONT-FAMILY: 'Arial', 'sans-serif'\">Love,</SPAN></P>\n<P class=MsoNormal><SPAN style=\"FONT-SIZE: 10pt; FONT-FAMILY: 'Arial', 'sans-serif'\">&nbsp;</SPAN></P>\n<P class=MsoNormal><SPAN style=\"FONT-SIZE: 10pt; FONT-FAMILY: 'Arial', 'sans-serif'\">Steve and Judy </SPAN></P></DIV></DIV><BR></DIV></div></body></html>","is_from_epstein":true,"attachments":0,"avatar_color":"#9c27b0","stars":4,"is_redacted":false}]