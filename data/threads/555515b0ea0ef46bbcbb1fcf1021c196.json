[{"id":"ea1b970e6587d23f4abbeb90f4e60fbb","from":"Lesley Groff","from_email":"lesley@nysgllc.com","to":"J. Epstein","to_list":[{"name":"J. Epstein","email":"jeeproject@yahoo.com"}],"cc_list":[],"subject":"FW: Washington Plenary Meeting","date":"2008-01-14T20:53:10.000Z","formatted_date":"Jan 14, 2008","formatted_time":"8:53 PM","body":" \n \n \n \n \n \n \nLesley Groff\nExecutive Assistant to Jeffrey Epstein\n \n \n\n________________________________\n\nFrom: Michael O'Neil [mailto:moneil@trilateral.org] \nSent: Monday, January 14, 2008 3:03 PM\nTo: moneil@trilateral.org\nCc: Mary Valder\nSubject: Washington Plenary Meeting\n\n\n\nThe Trilateral Commission\n\n   1156 FIFTEENTH STREET, N.W., Washington, D.C. 20005\n\n  Tel:  (202) 467-5410 * Fax:  (202) 467-5415\n\n \n\n \n\nTo:            Members and Participants\n\n \n\nFrom:        Michael O'Neil\n\n \n\nDate:        January 14, 2008\n\n \n\nSubject:    2008 Trilateral Commission Plenary Meeting\n\n \n\n    Attached please find an initial draft of the program for the 2008\nTrilateral Commission plenary meeting, which will be held in Washington,\nD.C. April 25-28, 2008.  The meeting will be held at the Ritz Carlton\nHotel, 2200 M Street, N.W., Washington, D.C. 20037.  \n\n \n\n    Also attached is a room reservation form.  Please return the\ncompleted form by March 14, 2008. \n\n \n\n    An updated version of the program and related materials will be\nforwarded to you as additional speakers are confirmed.    \n\n \n\n \n\n \n9\n\n","body_html":"<!DOCTYPE HTML PUBLIC \"-//W3C//DTD HTML 4.0 Transitional//EN\">\n<HTML xmlns=\"http://www.w3.org/TR/REC-html40\" xmlns:v = \n\"urn:schemas-microsoft-com:vml\" xmlns:o = \n\"urn:schemas-microsoft-com:office:office\" xmlns:w = \n\"urn:schemas-microsoft-com:office:word\" xmlns:m = \n\"http://schemas.microsoft.com/office/2004/12/omml\"><HEAD>\n<META http-equiv=Content-Type content=\"text/html; charset=us-ascii\">\n<META content=\"MSHTML 6.00.3790.94\" name=GENERATOR>\n<STYLE>@fo