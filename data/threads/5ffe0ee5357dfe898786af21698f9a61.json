-adjust: 100%;border-bottom: 0;\">\n                                        <tr>\n                                            <td valign=\"top\" class=\"headerContainer\" style=\"padding-top: 9px;padding-bottom: 9px;mso-table-lspace: 0pt;mso-table-rspace: 0pt;-ms-text-size-adjust: 100%;-webkit-text-size-adjust: 100%;\"></td>\n                                        </tr>\n                                    </table>\n                                    <!-- // END HEADER -->\n                                </td>\n                            </tr>\n                            <tr>\n                                <td align=\"left\" valign=\"top\" style=\"mso-table-lspace: 0pt;mso-table-rspace: 0pt;-ms-text-size-adjust: 100%;-webkit-text-size-adjust: 100%;\">\n                                    <!-- BEGIN BODY // -->\n                                    <table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" width=\"600\" id=\"templateBody\" style=\"border-collapse: collapse;mso-table-lspace: 0pt;mso-table-rspace: 0pt;-ms-text-size-adjust: 100%;-webkit-text-size-adjust: 100%;border-top: 0;border-bottom: 0;\">\n                                        <tr>\n                                            <td valign=\"top\" class=\"bodyContainer\" style=\"padding-top: 9px;padding-bottom: 9px;mso-table-lspace: 0pt;mso-table-rspace: 0pt;-ms-text-size-adjust: 100%;-webkit-text-size-adjust: 100%;\"><table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" width=\"100%\" class=\"mcnTextBlock\" style=\"border-collapse: collapse;mso-table-lspace: 0pt;mso-table-rspace: 0pt;-ms-text-size-adjust: 100%;-webkit-text-size-adjust: 100%;\">\n    <tbody class=\"mcnTextBlockOuter\">\n        <tr>\n            <td valign=\"top\" class=\"mcnTextBlockInner\" style=\"mso-table-lspace: 0pt;mso-table-rspace: 0pt;-ms-text-size-adjust: 100%;-webkit-text-size-adjust: 100%;\">\n\n                <table align=\"left\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" width=\"600\" class=\"mcnTextContentContainer\" style=\"border-collapse: collapse;mso-table-lspace: 0pt;mso-table-rspace: 0pt;-ms-text-size-adjust: 100%;-webkit-text-size-adjust: 100%;\">\n                    <tbody><tr>\n\n                        <td valign=\"top\" class=\"mcnTextContent\" style=\"padding-top: 9px;padding-right: 18px;padding-bottom: 9px;padding-left: 18px;mso-table-lspace: 0pt;mso-table-rspace: 0pt;-ms-text-size-adjust: 100%;-webkit-text-size-adjust: 100%;color: #202020;font-family: Helvetica;font-size: 15px;line-height: 150%;text-align: left;\">\n\n                            <div style=\"color: #222222;font-family: arial, sans-serif;font-size: 12.8000001907349px;line-height: normal;\">Hi&nbsp;jeffrey,<br>\n<br>\nIt's time for another product update from image32. We've been listening to our customers and adding new features to help make image32 more useful. Here are just a few of the new features we're rolling out...<br>\n<br>\n- Localizer lines in the viewer<br>\n- Four window <span style=\"color: #222222;font-family: arial,sans-serif;font-size: 12.8000001907349px;line-height: normal;\">layout</span>&nbsp;option<br>\n- Improved support for mobile browsers<br>\n- <span style=\"color: #222222;font-family: arial,sans-serif;font-size: 12.8000001907349px;line-height: normal;\">Improved support</span> for DICOM Structured Reports (SR)<br>\n- Support for larger file attachments<br>\n- Improved performance over low-bandwidth networks<br>\n<br>\nWe're rolling out these features over the next few days. If you want to see a sneak peak, go here and login with your regular username and password: <a href=\"http://image32.us6.list-manage1.com/track/click?u=1faec27b59029d1114f8d0e19&id=21fe92495c&e=d239b5474d\" target=\"_blank\" style=\"-ms-text-size-adjust: 100%;-webkit-text-size-adjust: 100%;color: #202020;font-weight: normal;text-decoration: underline;\">https://preview.image32.com</a><br>\n<br>\nWe hope you find many of the above improvements useful. Please let us know what else we can do to make image32 work better for you.</div>\n\n<div style=\"color: #222222;font-family: arial, sans-serif;font-size: 12.8000001907349px;line-height: normal;\">&nbsp;</div>\n\n<div style=\"color: #222222;font-family: arial, sans-serif;font-size: 12.8000001907349px;line-height: normal;\">Thanks,</div>\n\n<div style=\"color: #222222;font-family: arial, sans-serif;font-size: 12.8000001907349px;line-height: normal;\">The image32 team</div>\n\n<div style=\"color: #222222;font-family: arial, sans-serif;font-size: 12.8000001907349px;line-height: normal;\">&nbsp;</div>\n\n<div style=\"color: #222222;font-family: arial, sans-serif;font-size: 12.8000001907349px;line-height: normal;\"><a href=\"mailto:support@image32.com\" target=\"_blank\" style=\"-ms-text-size-adjust: 100%;-webkit-text-size-adjust: 100%;color: #202020;font-weight: normal;text-decoration: underline;\">support@image32.com</a></div>\n\n<div style=\"color: #222222;font-family: arial, sans-serif;font-size: 12.8000001907349px;line-height: normal;\"><a href=\"http://image32.us6.list-manage.com/track/click?u=1faec27b59029d1114f8d0e19&id=1262a5e763&e=d239b5474d\" target=\"_blank\" style=\"-ms-text-size-adjust: 100%;-webkit-text-size-adjust: 100%;color: #202020;font-weight: normal;text-decoration: underline;\">https://www.image32.com</a></div>\n\n                        </td>\n                    </tr>\n                </tbody></table>\n\n            </td>\n        </tr>\n    </tbody>\n</table></td>\n                                        </tr>\n                                    </table>\n                                    <!-- // END BODY -->\n                                </td>\n                            </tr>\n                            <tr>\n                                <td align=\"left\" valign=\"top\" style=\"mso-table-lspace: 0pt;mso-table-rspace: 0pt;-ms-text-size-adjust: 100%;-webkit-text-size-adjust: 100%;\">\n                                    <!-- BEGIN FOOTER // -->\n                               