n          <table class=MsoNormalTable border=0 cellspacing=0 cellpadding=0\n           width=\"100%\" style='width:100.0%'>\n           <tr>\n            <td style='padding:11.25pt 11.25pt 11.25pt 11.25pt'>\n            <table class=MsoNormalTable border=0 cellspacing=0 cellpadding=0\n             width=\"100%\" style='width:100.0%'>\n             <tr>\n              <td style='padding:0in 0in 0in 0in'>\n              <p class=MsoNormal style='line-height:18.0pt'><span\n              style='font-size:18.0pt;font-family:\"Arial\",\"sans-serif\";\n              color:#333333'>Eyes<o:p></o:p></span></p>\n              </td>\n             </tr>\n             <tr>\n              <td style='padding:0in 0in 0in 0in'>\n              <p class=MsoNormal style='line-height:11.25pt'><span\n              style='font-size:8.5pt;font-family:\"Arial\",\"sans-serif\";\n              color:#9A9A9A'>April 14, 2008<o:p></o:p></span></p>\n              </td>\n             </tr>\n             <tr>\n              <td style='padding:0in 0in 0in 0in'>\n              <p class=MsoNormal><img border=0 width=1 height=25\n              id=\"_x0000_i1048\"\n              src=\"http://www.manhattanusersguide.com/img/blank.gif\"><o:p></o:p></p>\n              </td>\n             </tr>\n             <tr>\n              <td style='padding:0in 0in 0in 0in'>\n              <p class=MsoNormal style='margin-bottom:12.0pt;line-height:11.25pt'><span\n              style='font-size:8.5pt;font-family:\"Arial\",\"sans-serif\";\n              color:#333333'>Today, the eyes have it.<br>\n              <br>\n              <br>\n              </span><!--[if gte vml 1]><v:shapetype id=\"_x0000_t75\" \n               coordsize=\"21600,21600\" o:spt=\"75\" o:preferrelative=\"t\" path=\"m@4@5l@4@11@9@11@9@5xe\" \n               filled=\"f\" stroked=\"f\">\n               <v:stroke joinstyle=\"miter\" />\n               <v:formulas>\n                <v:f eqn=\"if lineDrawn pixelLineWidth 0\" />\n                <v:f eqn=\"sum @0 1 0\" />\n                <v:f eqn=\"sum 0 0 @1\" />\n                <v:f eqn=\"prod @2 1 2\" />\n                <v:f eqn=\"prod @3 21600 pixelWidth\" />\n                <v:f eqn=\"prod @3 21600 pixelHeight\" />\n                <v:f eqn=\"sum @0 0 1\" />\n                <v:f eqn=\"prod @6 1 2\" />\n                <v:f eqn=\"prod @7 21600 pixelWidth\" />\n                <v:f eqn=\"sum @8 21600 0\" />\n                <v:f eqn=\"prod @7 21600 pixelHeight\" />\n                <v:f eqn=\"sum @10 21600 0\" />\n               </v:formulas>\n               <v:path o:extrusionok=\"f\" gradientshapeok=\"t\" o:connecttype=\"rect\" />\n               <o:lock v:ext=\"edit\" aspectratio=\"t\" />\n              </v:shapetype><v:shape id=\"_x0000_s1026\" type=\"#_x0000_t75\" \n               alt=\"\" style='position:absolute;margin-left:-319.5pt;\n               margin-top:-264.75pt;width:42.75pt;height:112.5pt;z-index:251655680;\n               mso-wrap-distance-left:6.75pt;mso-wrap-distance-top:2.25pt;\n               mso-wrap-distance-right:6.75pt;mso-wrap-distance-bottom:2.25pt;\n               mso-position-horizontal:absolute;\n               mso-position-horizontal-relative:text;mso-position-vertical:absolute;\n               mso-position-vertical-relative:line' o:allowoverlap=\"f\">\n               <v:imagedata src=\"http://www.manhattanusersguide.com/aux/041408a.jpg\" />\n               <w:wrap type=\"square\"/>\n              </v:shape><![endif]--><![if !vml]><img width=57 height=150\n              src=\"http://www.manhattanusersguide.com/aux/041408a.jpg\"\n              align=left hspace=9 vspace=3 v:shapes=\"_x0000_s1026\"><![endif]><span\n              style='font-size:8.5pt;font-family:\"Arial\",\"sans-serif\";\n              color:#333333'><br>\n              We're not sure that the French eye drops <a\n              href=\"http://www.newlondonpharmacy.com/innoxa/apothecary-products.htm\"\n              target=\"_blank\"><b><span style='color:#009999;text-decoration:\n              none'>Gouttes Bleues</span></b></a> are actually <i>good</i> for\n              your eyes. However, they do give them a noticeably bright sparkle\n              that we've never gotten from anything else. </span><span\n              style='font-size:8.5pt;font-family:\"MS Gothic\";color:#333333'>\u2028</span><span\n              style='font-size:8.5pt;font-family:\"Arial\",\"sans-serif\";\n              color:#333333'><br>\n              <br>\n              <br>\n              <br>\n              <br>\n              Over 52,000 people have had their sight restored through corneal\n              transplants made possible by donations to the <a\n              href=\"http://www.eyedonation.org/\" target=\"_blank\"><b><span\n              style='color:#009999;text-decoration:none'>Eye-Bank for Sight\n              Restoration</span></b></a>. Sign up to be a donor <a\n              href=\"http://www.eyedonation.org/sign.html\" target=\"_blank\"><b><span\n              style='color:#009999;text-decoration:none'>here</span></b></a>.<br>\n              <br>\n              <br>\n              <br>\n              <br>\n              </span><!--[if gte vml 1]><v:shape id=\"_x0000_s1027\" type=\"#_x0000_t75\" \n               alt=\"\" style='position:absolute;margin-left:-319.5pt;\n               margin-top:-467.25pt;width:39.75pt;height:105pt;z-index:251656704;\n               mso-wrap-distance-left:6.75pt;mso-wrap-distance-top:2.25pt;\n               mso-wrap-distance-right:6.75pt;mso-wrap-distance-bottom:2.25pt;\n               mso-position-horizontal:absolute;\n               mso-position-horizontal-relative:text;mso-position-vertical:absolute;\n               mso-position-vertical-relative:line' o:allowoverlap=\"f\">\n               <v:imagedata src=\"http://www.manhattanusersguide.com/aux/041408b.jpg\" />\n               <w:wrap type=\"square\"/>\n              </v:shape><![endif]--><![if !vml]><img width=53 height=140\n              src=\"http://www.manhattanusersguide.com/aux/041408b.jpg\"\n              align=left hspace=9 vspace=3 v:shapes=\"_x0000_s1027\"><![endif]><span\n              style='font-size:8.5pt;font-family:\"Arial\",\"sans-serif\";\n              color:#333333'>Finding a perfect mascara can be an elusive\n              pursuit, but many people think <a\n              href=\"http://www.sephora.com/browse/product.jhtml?id=P40404\"\n              target=\"_blank\"><b><span style='color:#009999;text-decoration:\n              none'>Diorshow</span></b></a> is pretty close. Available in black\n              as well as azure blue and chestnut. <br>\n              <br>\n              <br>\n              <br>\n              <br>\n              <br>\n              For 70 years, H. L. Purdy Opticians has been the gold standard in\n              eyewear stores (they have two shops on Madison, one on\n              Lexington). They can also do a lot of fancy handiwork when it\n              comes to <a href=\"http://hlpurdy.com\" target=\"_blank\"><b><span\n              style='color:#009999;text-decoration:none'>customizing</span></b></a>:\n              they'll put your prescription into everything from telescopes to\n              opera glasses to diving masks. They can even hand-paint a frame\n              to match an outfit. <br>\n              <br>\n              <br>\n              <br>\n              </span><!--[if gte vml 1]><v:shape id=\"_x0000_s1028\" type=\"#_x0000_t75\" \n               alt=\"\" style='position:absolute;margin-left:-319.5pt;\n               margin-top:-681pt;width:124.5pt;height:93.75pt;z-index:251657728;\n               mso-wrap-distance-left:6.75pt;mso-wrap-distance-top:2.25pt;\n               mso-wrap-distance-right:6.75pt;mso-wrap-distance-bottom:2.25pt;\n               mso-position-horizontal:absolute;\n               mso-position-horizontal-relative:text;mso-position-vertical:absolute;\n               mso-position-vertical-relative:line' o:allowoverlap=\"f\">\n               <v:imagedata src=\"http://www.manhattanusersguide.com/aux/041408c.jpg\" />\n               <w:wrap type=\"square\"/>\n              </v:shape><![endif]--><![if !vml]><img width=166 height=125\n              src=\"http://www.manhattanusersguide.com/aux/041408c.jpg\"\n              align=left hspace=9 vspace=3 v:shapes=\"_x0000_s1028\"><![endif]><span\n              style='font-size:8.5pt;font-family:\"Arial\",\"sans-serif\";\n              color:#333333'><br>\n              The grays of winter are finally giving way to eye-opening colors,\n              as these magnolia trees next to Cleopatra's Needle in Central\n              Park show.<br>\n              <br>\n              <br>\n              <br>\n              <br>\n              <br>\n              <br>\n              </span><!--[if gte vml 1]><v:shape id=\"_x0000_s1029\" type=\"#_x0000_t75\" \n               alt=\"\" style='position:absolute;margin-left:-319.5pt;\n               margin-top:-838.5pt;width:65.25pt;height:105pt;z-index:251658752;\n               mso-wrap-distance-left:6.75pt;mso-wrap-distance-top:2.25pt;\n               mso-wrap-distance-right:6.75pt;mso-wrap-distance-bottom:2.25pt;\n               mso-position-horizontal:absolute;\n               mso-position-horizontal-relative:text;mso-position-vertical:absolute;\n               mso-position-vertical-relative:line' o:allowoverlap=\"f\">\n               <v:imagedata src=\"http://www.manhattanusersguide.com/aux/041408d.jpg\" />\n               <w:wrap type=\"square\"/>\n              </v:shape><![endif]--><![if !vml]><img width=87 height=140\n              src=\"http://www.manhattanusersguide.com/aux/041408d.jpg\"\n              align=left hspace=9 vspace=3 v:shapes=\"_x0000_s1029\"><![endif]><span\n              style='font-size:8.5pt;font-family:\"Arial\",\"sans-serif\";\n              color:#333333'><br>\n              Last chance to feast your eyes on Parmigianino's <i>Antea</i>,\n              the exquisite painting that makes a solo exhibition at the <a\n              href=\"http://www.frick.org/exhibitions/Antea/index.htm\"\n              target=\"_blank\"><b><span style='color:#009999;text-decoration:\n              none'>Frick</span></b></a>. It closes on April 27th.<o:p></o:p></span></p>\n              </td>\n             </tr>\n            </table>\n            </td>\n           </tr>\n          </table>\n          </td>\n         </tr>\n         <tr>\n          <td style='padding:0in 0in 0in 0in'>\n          <p class=MsoNormal><img border=0 width=332 height=8 id=\"_x0000_i1049\"\n          src=\"http://www.manhattanusersguide.com/img/email/bar_sponsor.gif\"><o:p></o:p></p>\n          </td>\n         </tr>\n         <tr>\n          <td style='padding:0in 0in 0in 0in'>\n          <table class=MsoNormalTable border=0 cellspacing=0 cellpadding=0\n           width=\"100%\" style='width:100.0%'>\n           <tr style='height:14.25pt'>\n            <td style='padding:0in 0in 0in 0in;height:14.25pt'>\n            <p class=MsoNormal><img border=0 width=111 height=19\n            id=\"_x0000_i1050\"\n            src=\"http://www.manhattanusersguide.com/img/sponsor_links.gif\"><o:p></o:p></p>\n            </td>\n           </tr>\n           <tr>\n            <td style='padding:0in 0in 0in 0in'>\n            <table class=MsoNormalTable border=0 cellspacing=0 cellpadding=0\n             width=\"100%\" style='width:100.0%'>\n             <tr>\n              <td style='padding:9.75pt 9.75pt 9.75pt 9.75pt'>\n              <div align=center>\n              <table class=MsoNormalTable border=0 cellspacing=0 cellpadding=0\n               width=\"100%\" style='width:100.0%'>\n               <tr>\n                <td width=17 style='width:12.75pt;padding:0in 0in 0in 0in'>\n                <p class=MsoNormal><img border=0 width=17 height=1\n                id=\"_x0000_i1051\"\n                src=\"http://www.manhattanusersguide.com/img/blank.gif\"><o:p></o:p></p>\n                </td>\n                <td valign=top style='padding:0in 0in 0in 0in'>\n                <p class=MsoNormal style='margin-bottom:12.0pt;line-height:\n                11.25pt'><b><span style='font-size:8.5pt;font-family:\"Arial\",\"sans-serif\";\n                color:#333333'>Discover the Alexander Technique. Re-discover\n                your natural ease.</span></b><span style='font-size:8.5pt;\n                font-family:\"Arial\",\"sans-serif\";color:#333333'> Are you living\n                with undue tension? Discover this practical method for better\n                posture, less pain, and mind-body integration. Uncover you\n                body's innate ease. Certified instructor Amira Glaser\n                introduces this holistic approach to easier moving, breathing\n                and being. For more information: visit <a\n                href=\"http://www.amiraglaser.com/\" target=\"_blank\">www.amiraglaser.com</a>.<o:p></o:p></span></p>\n                <p class=MsoNormal align=center style='text-align:center;\n                line-height:11.25pt'><span style='font-size:8.5pt;font-family:\n                \"Arial\",\"sans-serif\";color:#333333'>\u2022<o:p></o:p></span></p>\n                <p class=MsoNormal style='margin-bottom:12.0pt;line-height:\n                11.25pt'><span style='font-size:8.5pt;font-family:\"Arial\",\"sans-serif\";\n                color:#333333'><br>\n                <b>A MET PREMIERE</b>: Philip Glass's landmark opera <b><i>Satyagraha</i></b>\n                is a moving, musical meditation on <b>Mahatma Gandhi's</b>\n                formative experiences in South Africa, which shaped his\n                visionary philosophy of <b>Satyagraha</b> (Sanskrit for &quot;truth-force&quot;).\n                Experience this sensational new production, created by Phelim\n                McDermott and designer Julian Crouch (<i>Shockheaded Peter</i>),\n                fresh from its hit run in London. Improvisational puppetry and\n                evocative projections come together in what <i>The Times</i>\n                (London) called a &quot;<b>masterwork of theatrical intensity</b>.&quot;\n                6 performances left! April 14, 19 mat, 22, 25, 28, May 1. Visit\n                <a\n                href=\"http://www.metoperafamily.org/metopera/season/production.aspx?id=9251\"\n                target=\"_blank\">metopera.org</a> or call <b>(212) 362-6000</b>\n                for ticket availability.<o:p></o:p></span></p>\n                </td>\n                <td width=17 style='width:12.75pt;padding:0in 0in 0in 0in'>\n                <p class=MsoNormal><img border=0 width=17 height=1\n                id=\"_x0000_i1052\"\n                src=\"http://www.manhattanusersguide.com/img/blank.gif\"><o:p></o:p></p>\n                </td>\n               </tr>\n              </table>\n              </div>\n              </td>\n             </tr>\n            </table>\n            </td>\n           </tr>\n          </table>\n          </td>\n         </tr>\n         <tr style='height:2.25pt'>\n          <td style='padding:0in 0in 0in 0in;height:2.25pt'>\n          <p class=MsoNormal><img border=0 width=1 height=3 id=\"_x0000_i1053\"\n          src=\"http://www.manhattanusersguide.com/img/blank.gif\"><o:p></o:p></p>\n          </td>\n         </tr>\n         <tr style='height:18.75pt'>\n          <td style='background:#64DDDD;padding:0in 0in 0in 0in;height:18.75pt'>\n          <p class=MsoNormal><img border=0 width=72 height=25 id=\"_x0000_i1054\"\n          src=\"http://www.manhattanusersguide.com/img/joe_info.gif\"><o:p></o:p></p>\n          </td>\n         </tr>\n         <tr style='height:2.25pt'>\n          <td style='padding:0in 0in 0in 0in;height:2.25pt'>\n          <p class=MsoNormal><img border=0 width=1 height=3 id=\"_x0000_i1055\"\n          src=\"http://www.manhattanusersguide.com/img/blank.gif\"><o:p></o:p></p>\n          </td>\n         </tr>\n         <tr>\n          <td style='backgroun