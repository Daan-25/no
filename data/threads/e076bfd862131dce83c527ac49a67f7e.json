/* Image borders & formatting */\nimg {\noutline: none;\ntext-decoration: none;\n-ms-interpolation-mode: bicubic;\n}\na img {\nborder: none;\n}\n/* Re-style iPhone automatic links (eg. phone numbers) */\n.appleLinks a {\ncolor: #666666;\ntext-decoration: none;\n}\n.appleLinksFooter a {\ncolor: #a1a1a1;\ntext-decoration: none;\n}\n/* Media Query for mobile */\n@media only screen and (max-width:480px) {\ntd[class=\"web\"], table[class=\"web\"], div[class=\"web\"], br[class=\"web\"], span[class=\"web\"] {\ndisplay: none !important;\n}\n/* This resizes tables and images to be 100% wide with a proportionate width */\n*[class=\"content-width\"] {\nwidth: 100% !important;\nheight: auto !important;\n}\ntd[class=\"full-width\"], table[class=\"full-width\"] {\nwidth: 100% !important;\n}\ntd[class=\"mobile-headline\"] {\nfont-size: 26px !important;\nline-height: 28px !important;\n}\ntd[class=\"mobile-text\"], table[class=\"mobile-text\"] {\nfont-size: 15px !important;\nline-height: 21px !important;\n}\ntd[class=\"hd\"] {\nfont-size: 16px !important;\nline-height: 21px !important;\npadding-top: 16px !important;\n}\ntd[class=\"mobile-subhead\"] {\nfont-size: 28px !important;\nline-height: 30px !important;\n}\na[class=\"button\"] {\nwidth: 260px !important;\n}\ntable[class=\"footer-content\"], td[class=\"footer-content\"] {\nclear: both !important;\ndisplay: block !important;\nwidth: auto !important;\n}\ntd[class=\"mobile-spacer\"], div[class=\"mobile-spacer\"] {\nwidth: 22px !important;\n}\ntd[class=\"logo\"] {\nwidth: auto !important;\n}\n}\n</STYLE>\n\n<META name=viewport content=\"width=device-width, initial-scale=1.0\">\n<DIV\nstyle=\"FONT-SIZE: 1px; OVERFLOW: hidden; COLOR: #f0f0f0; DISPLAY: none; VISIBILITY: hidden\">Log\nin to your Adobe I.D. today</DIV><!--there's an extra wrapper table here - this allows us to set the page background in webmail clients (where the body tag is ignored) -->\n<TABLE style=\"BACKGROUND-COLOR: #f0f0f0\" cellSpacing=0 cellPadding=0\nwidth=\"100%\" bgColor=#f0f0f0 border=0>\n  <TBODY>\n  <TR>\n    <TD vAlign=top align=center><!--table containg the main email - this will resize for mobile-->\n      <TABLE class=content-width style=\"WIDTH: 600px; BACKGROUND-COLOR: #f0f0f0\"\n      cellSpacing=0 cellPadding=0 width=600 align=center bgColor=#f0f0f0\n      border=0>\n        <TBODY>\n        <TR>\n          <TD>\n            <TABLE class=content-width\n            style=\"WIDTH: 600px; BACKGROUND-COLOR: #f0f0f0\" cellSpacing=0\n            cellPadding=0 width=600 align=center bgColor=#f0f0f0 border=0>\n              <TBODY>\n              <TR>\n                <TD class=web\n                style=\"FONT-SIZE: 11px; FONT-FAMILY: Arial, Helvetica, sans-serif; COLOR: #666666; PADDING-BOTTOM: 9px; PADDING-TOP: 12px; LINE-HEIGHT: 13px\"\n                align=right><a style=\"COLOR: #2b9af3\" href=\"http://t.info.adobesystems.com//r/?id=h6a0f067d,85289f46,856107a2&p1=%40C2FiqNc6Pgv4LXDbEKIU1Uu7PWt%2F0WJNWGU0AgCFBRk%3D\" target=\"_blank\" alias=\"Read Online\" _type=\"mirrorPage\" _label=\"Mirror Page\">Read&nbsp;online</A></TD></TR></TBODY></TABLE></TD></TR>\n        <TR>\n          <TD style=\"VERTICAL-ALIGN: top\" bgColor=#ffffff><!-- header -->\n            <TABLE class=full-width style=\"WIDTH: 600px\" cellSpacing=0\n            cellPadding=0 width=600 align=center border=0>\n              <TBODY>\n              <TR>\n                <TD class=logo\n                style=\"FONT-SIZE: 12px; FONT-FAMILY: Arial, Helvetica, sans-serif; COLOR: #ffffff; TEXT-ALIGN: right; LINE-HEIGHT: 18px\"\n                vAlign=top width=588 align=right><IMG class=logo\n                  style=\"VERTICAL-ALIGN: top; DISPLAY: inline-block; BACKGROUND-COLOR: #ff0000\"\n                  border=0 hspace=0 alt=Adobe\n                  src=\"http://landing.adobe.com/dam/global/images/adobe-logo.red-tag.78x128.png\"\n                  width=39 height=64></TD>\n                <TD\n        width=12>&nbsp;</TD></TR></TBODY></TABLE><!-- END header --></TD></TR>\n        <TR>\n          <TD style=\"PADDING-BOTTOM: 40px\" bgColor=#ffffff align=left>\n            <TABLE cellSpacing=0 cellPadding=0 width=\"100%\" border=0>\n              <TBODY>\n              <TR>\n                <TD class=mobile-spacer width=30>&nbsp;</TD>\n                <TD class=hd\n                style=\"FONT-SIZE: 12px; FONT-FAMILY: Arial, Helvetica, sans-serif; COLOR: #000000; LINE-HEIGHT: 18px\"><STRONG>Your\n                  Adobe account will expire&nbsp;soon.</STRONG></TD>\n                <TD class=mobile-spacer width=30>&nbsp;</TD></TR>\n              <TR>\n                <TD class=mobile-spacer width=30>&nbsp;</TD>\n                <TD class=mobile-text\n                style=\"FONT-SIZE: 12px; FONT-FAMILY: Arial, Helvetica, sans-serif; COLOR: #666666; PADDING-TOP: 24px; LINE-HEIGHT: 18px\">Dear\n                  Adobe\n                  Customer,</TD>\n                <TD class=mobile-spacer width=30>&nbsp;</TD></TR>\n              <TR>\n                <TD class=mobile-spacer width=30>&nbsp;</TD>\n                <TD class=mobile-text\n                style=\"FONT-SIZE: 12px; FONT-FAMILY: Arial, Helvetica, sans-serif; COLOR: #666666; PADDING-TOP: 12px; LINE-HEIGHT: 18px\">We've\n                  noticed you have not logged in to your Adobe account in more\n                  than a year. In keeping with our policies, we are contacting\n                  you to let you know your Adobe ID will expire on 12/27/2017.\n                  If you take no action, your Adobe ID will no longer be valid,\n                  you will no longer have access to content you may have stored\n                  on our servers, and this account will be&nbsp;closed.</TD>\n                <TD class=mobile-spacer width=30>&nbsp;</TD></TR>\n              <TR>\n                <TD class=mobile-spacer width=30>&nbsp;</TD>\n                <TD class=mobile-text\n                style=\"FONT-SIZE: 12px; FONT-FAMILY: Arial, Helvetica, sans-serif; COLOR: #666666; PADDING-TOP: 12px; LINE-HEIGHT: 18px\"\n                align=center>Your Adobe ID is: <STRONG>JEFFREYO7</STRONG></TD>\n                <TD class=mobile-spacer width=30>&nbsp;</TD></TR>\n              <TR>\n                <TD class=mobile-spacer width=30>&nbsp;</TD>\n                <TD class=mobile-text\n                style=\"FONT-SIZE: 12px; FONT-FAMILY: Arial, Helvetica, sans-serif; COLOR: #666666; PADDING-TOP: 12px; LINE-HEIGHT: 18px\">In\n                  order to maintain your Adobe ID, simply log in prior to\n                  12/27/2017. If you would like, you can sign up for a free <a style=\"TEXT-DECORATION: none; COLOR: #2b9af3\" href=\"http://t.info.adobesystems.com//r/?id=h6a0f067d,85289f46,856107a3&p1=DD5B1NNK\">Acrobat\n                  trial</A> or <a style=\"TEXT-DECORATION: none; COLOR: #2b9af3\" href=\"http://t.info.adobesystems.com//r/?id=h6a0f067d,85289f46,856107a4&p1=D8F91SDL\">Photoshop\n                  trial</A>, which requires your Adobe ID. With an active Adobe\n                  ID, you can access the latest trial offers, register for\n                  events such as MAX, and participate in our\nuser&nbsp;groups.</TD>\n                <TD class=mobile-spacer width=30>&nbsp;</TD></TR>\n              <TR>\n                <TD class=mobile-spacer width=30>&nbsp;</TD>\n                <TD class=mobile-text\n                style=\"FONT-SIZE: 12px; FONT-FAMILY: Arial, Helvetica, sans-serif; COLOR: #666666; PADDING-TOP: 12px; LINE-HEIGHT: 18px\">Sign\n                  in with your Adobe ID listed above to get access to all these\n                  features and&nbsp;more.<STRONG></STRONG></TD>\n                <TD class=mobile-spacer width=30>&nbsp;</TD></TR>\n              <TR>\n                <TD class=mobile-spacer width=30>&nbsp;</TD>\n                <TD class=mobile-text\n                style=\"FONT-SIZE: 12px; FONT-FAMILY: Arial, Helvetica, sans-serif; COLOR: #2b9af3; PADDING-BOTTOM: 3px; TEXT-ALIGN: center; PADDING-TOP: 15px; LINE-HEIGHT: 18px\"\n                align=center>\n                  <DIV><!--[if mso]>\n<table class=\"full-width\" align=\"center\" width=\"180\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" style=\"width:180px\">\n<tr>\n<td height=\"38\" valign=\"middle\" style=\"background-color:#2b9af3;\">\n<center>\n<![endif]--><a class=\"button\" style=\"FONT-SIZE: 14px; TEXT-DECORATION: none; FONT-FAMILY: Arial,Helvetica,sans-serif; WIDTH: 180px; COLOR: #ffffff; TEXT-ALIGN: center; DISPLAY: inline-block; LINE-HEIGHT: 38px; BACKGROUND-COLOR: #2b9af3; -webkit-text-size-adjust: none; border-radius: 6px\" href=\"http://t.info.adobesystems.com//r/?id=h6a0f067d,85289f46,856107a5&p1=D4P81X4M\" target=\"_blank\"><STRONG>Log in now</STRONG></A><!--[if mso]>\n</center>\n</td>\n</tr>\n</table>\n<![endif]-->\n                  </DIV></TD>\n                <TD class=mobile-spacer\n        width=30>&nbsp;</TD></TR></TBODY></TABLE></TD></TR>\n        <TR>\n          <TD vAlign=top align=center><!-- campaign -->\n            <TABLE class=content-width\n            style=\"WIDTH: 600px; BACKGROUND-COLOR: #f0f0f0\" cellSpacing=0\n            cellPadding=0 width=600 align=center bgColor=#f0f0f0 border=0>\n              <TBODY>\n              <TR>\n                <TD\n                style=\"FONT-SIZE: 12px; FONT-FAMILY: Arial, Helvetica, sans-serif; COLOR: #666666; TEXT-ALIGN: center; PADDING-TOP: 20px; LINE-HEIGHT: 12px\"\n                vAlign=top align=center><IMG\n                  style=\"VERTICAL-ALIGN: top; DISPLAY: inline-block\" border=0\n                  hspace=0 alt=\"Enabled by Adobe Campaign\"\n                  src=\"http://landing.adobe.com/dam/global/images/enabled-by-adobe-campaign.light.280x60.png\"\n                  width=140 height=30></TD></TR></TBODY></TABLE><!-- END campaign -->\n            <TABLE class=content-width style=\"WIDTH: 600px\" cellSpacing=0\n            cellPadding=0 width=600 border=0>\n              <TBODY>\n              <TR>\