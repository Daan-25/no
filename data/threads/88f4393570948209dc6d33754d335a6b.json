[{"id":"88f4393570948209dc6d33754d335a6b","from":"Lesley Groff","from_email":"lesley@nysgllc.com","to":"J. Epstein","to_list":[{"name":"J. Epstein","email":"jeeproject@yahoo.com"}],"cc_list":[],"subject":"FW:","date":"2008-03-14T21:35:45.000Z","formatted_date":"Mar 14, 2008","formatted_time":"9:35 PM","body":" \n \n \n \n \n \n \nLesley Groff\nExecutive Assistant to Jeffrey Epstein\n \n \n\n________________________________\n\nFrom: Nili Priell [mailto:nilipr@netvision.net.il] \nSent: Friday, March 14, 2008 5:17 PM\nTo: Lesley Groff\nSubject: \n\n\n\nDear Lesley\n\nPlease forward to Jeffrey- thanks.\n\n \n\n \n\nDear Jeffrey,\n\nI have already 3 customers based on the same agreement I have forwarded\nyou. A more detailed one, I feel, will be complicated, and will need a\nlaw firm involvement. \n\nThe concept is to be based on mutual trust and understanding. \n\nIt worked for Ehud in the past and I believe it can work for Taurus too.\n\nFor the time being. I prefer to follow this type of agreement.\n\nWarm regards,\n\nnili\n\n \n\n","body_html":"<!DOCTYPE HTML PUBLIC \"-//W3C//DTD HTML 4.0 Transitional//EN\">\n<HTML><HEAD>\n<META http-equiv=Content-Type content=\"text/html; charset=us-ascii\">\n<META content=\"MSHTML 6.00.3790.94\" name=GENERATOR>\n<STYLE>@page Section1 {size: 595.3pt 841.9pt; margin: 72.0pt 90.0pt 72.0pt 90.0pt; }\nP.MsoNormal {\n\tFONT-SIZE: 12pt; MARGIN: 0cm 0cm 0pt; DIRECTION: rtl; FONT-FAMILY: \"Times New Roman\"; unicode-bidi: embed; TEXT-ALIGN: right\n}\nLI.MsoNormal {\n\tFONT-SIZE: 12pt; MARGIN: 0cm 0cm 0pt; DIRECTION: rtl; FONT-FAMILY: \"Times New Roman\"; unicode-bidi: embed; TEXT-ALIGN: right\n}\nDIV.MsoNormal {\n\tFONT-SIZE: 12pt; MARGIN: 0cm 0cm 0pt; DIRECTION: rtl; FONT-FAMILY: \"Times New Roman\"; unicode-bidi: embed; TEXT-ALIGN: right\n}\nA:link {\n\tCOLOR: blue; TEXT-DECORATION: underline\n}\nSPAN.MsoHyperlink {\n\tCOLOR: blue; TEXT-DECORATION: underline\n}\nA:visited {\n\tCOLOR: purple; TEXT-DECORATION: underline\n}\nSPAN.MsoHyperlin