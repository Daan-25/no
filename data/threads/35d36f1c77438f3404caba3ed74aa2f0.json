[{"id":"1ae349ebb363f0d65de9d5c0aebc4544","from":"Stotter, Manuela","from_email":"MStotter@Related.com","to":"jeeproject@yahoo.com","to_list":[{"name":"jeeproject@yahoo.com","email":"jeeproject@yahoo.com"}],"cc_list":[],"subject":"catch up","date":"2008-01-14T16:03:09.000Z","formatted_date":"Jan 14, 2008","formatted_time":"4:03 PM","body":"Hallo Jeffrey,\n\n \n\nI'm sorry I missed you last week. I really hoped to see you and catch up a\nbit. I know you are quite busy and my schedule is not as flexible any more.\n\nI may just stop by at your office to say HI to everybody, but I really wanted\nto see you. I always feel that at the end you were the only person who\nbelieved in me and gave me the opportunity to come to NYC.\n\nMy life changed very much and now I'm very stable and happy. I would not be\nwhere I'm without your initial support.\n\nWell, that's all. THANKS was the only thing I came to say to you.\n\n \n\nLet me know if you ever want to see me and I can stop at 9th 71st street.\n\n \n\nHave a good day, wherever you are today,\n\n \n\nM\n\n \n\nManuela E. St\u00f6tter\n\nRELATED\n\n60 Columbus Circle\n\nNew York, NY 10023\n\nTel: 212.801.3796\n\nCell: 917.498.5285\n\nFax: 212.801.3727\n\nwww.related.com\n\n \n\n \n\n","body_html":"<html xmlns:o=\"urn:schemas-microsoft-com:office:office\" xmlns:w=\"urn:schemas-microsoft-com:office:word\" xmlns:st1=\"urn:schemas-microsoft-com:office:smarttags\" xmlns=\"http://www.w3.org/TR/REC-html40\">\n\n<head>\n<meta http-equiv=Content-Type content=\"text/html; charset=iso-8859-1\">\n<meta name=Generator content=\"Microsoft Word 11 (filtered medium)\">\n<o:SmartTagType namespaceuri=\"urn:schemas-microsoft-com:office:smarttags\"\n name=\"PostalCode\"/>\n<o:SmartTagType namespaceuri=\"urn:schemas-microsoft-com:office:smarttags\"\n name=\"State\"/>\n<o:SmartTagType namespaceuri=\"urn:schemas-microsoft-com:office:smarttags\"\n name=\"City\"/>\n<o:SmartTagType namespaceuri=\"urn:schemas-microsoft-com:office:smarttags\"\n name=\"place\"/>\n<o:SmartTagType namespaceuri=\"urn:schemas-microsoft-com:office:smarttags\"\n name=\"Street\"/>\n<o:SmartTagType namespaceuri=\"urn:schemas-microsoft-com:office:smarttags\"\n name=\"address\"/>\n<!--[if !mso]>\n<style>\nst1\\:*{behavior:url(#default#ieooui) }\n</style>\n<![endif]-->\n<style>\n<!--\n /* Font Definitions */\n @font-face\n\t{font-family:\"Comic Sans MS\";\n\tpanose-1:3 15 7 2 3 3 2 2 2 4;}\n@font-face\n\t{font-family:Papyrus;\n\tpanose-1:3 7 5 2 6 5 2 3 2 5;}\n@font-face\n\t{font-family:\"Copperplate Gothic Light\";\n\tpanose-1:2 14 5 7 2 2 6 2 4 4;}\n /* Style Definitions */\n p.MsoNormal, li.MsoNormal, div.MsoNormal\n\t{margin:0in;\n\tmargin-bottom:.0001pt;\n\tfont-size:12.0pt;\n\tfont-family:\"Times New Roman\";}\na:link, span.MsoHyperlink\n\t{color:blue;\n\ttext-decoration:underline;}\na:visited, span.MsoHyperlinkFollowed\n\t{color:purple;\n\ttext-decoration:underline;}\nspan.EmailStyle17\n\t{mso-style-type:personal-compose;\n\tfont-family:\"Comic Sans MS\";\n\tcolor:navy;\n\tfont-weight:normal;\n\tfont-style:normal;\n\ttext-decoration:none none;}\n@page Section1\n\t{size:8.5in 11.0in;\n\tmargin:1.0in 1.25in 1.0in 1.25in;}\ndiv.Section1\n\t{page:Section1;}\n-->\n</style>\n\n</head>\n\n<body lang=EN-US link=blue vlink=purple>\n\n<div class=Section1>\n\n<p class=MsoNormal><font size=2 color=navy face=\"Comic Sans MS\"><span\nstyle='font-size:10.0pt;font-family:\"Comic Sans MS\";color:navy'>Hallo Jeffrey,<o:p></o:p></span></font></p>\n\n<p class=MsoNormal><font size=2 color=navy face=\"Comic Sans MS\"><span\nstyle='font-size:10.0pt;font-family:\"Comic Sans MS\";color:navy'><o:p>&nbsp;</o:p></span></font></p>\n\n<p class=MsoNormal><font size=2 color=navy face=\"Comic Sans MS\"><span\nstyle='font-size:10.0pt;font-family:\"Comic Sans MS\";color:navy'>I&#8217;m sorry\nI missed you last week. I really hoped to see you and catch up a bit. I know\nyou are quite busy and my schedule is not as flexible any more.<o:p></o:p></span></font></p>\n\n<p class=MsoNormal><font size=2 color=navy face=\"Comic Sans MS\"><span\nstyle='font-size:10.0pt;font-family:\"Comic Sans MS\";color:navy'>I may just stop\nby at your office to say HI to everybody, but I really wanted to see you. I\nalways feel that at the end you were the only person who believed in me and\ngave me the opportunity to come to NYC.<o:p></o:p></span></font></p>\n\n<p class=MsoNormal><font size=2 color=navy face=\"Comic Sans MS\"><span\nstyle='font-size:10.0pt;font-family:\"Comic Sans MS\";color:navy'>My life changed\nvery much and now I&#8217;m very stable and happy. I would not be where I&#8217;m\nwithout your initial support.<o:p></o:p></span></font></p>\n\n<p class=MsoNormal><font size=2 color=navy face=\"Comic Sans MS\"><span\nstyle='font-size:10.0pt;font-family:\"Comic Sans MS\";color:navy'>Well, that&#8217;s\nall. THANKS was the only thing I came to say to you.<o:p></o:p></span></font></p>\n\n<p class=MsoNormal><font size=2 color=navy face=\"Comic Sans MS\"><span\nstyle='font-size:10.0pt;font-family:\"Comic Sans MS\";color:navy'><o:p>&nbsp;</o:p></span></font></p>\n\n<p class=MsoNormal><font size=2 color=navy face=\"Comic Sans MS\"><span\nstyle='font-size:10.0pt;font-family:\"Comic Sans MS\";color:navy'>Let me know if\nyou ever want to see me and I can stop at 9<sup>th</sup> <st1:Street w:st=\"on\"><st1:address\n w:st=\"on\">71<sup>st</sup> street</st1:address></st1:Street>.<o:p></o:p></span></font></p>\n\n<p class=MsoNormal><font size=2 color=navy face=\"Comic Sans MS\"><span\nstyle='font-size:10.0pt;font-family:\"Comic Sans MS\";color:navy'><o:p>&nbsp;</o:p></span></font></p>\n\n<p class=MsoNormal><font size=2 color=navy face=\"Comic Sans MS\"><span\nstyle='font-size:10.0pt;font-family:\"Comic Sans MS\";color:navy'>Have a good\nday, wherever you are today,<o:p></o:p></span></font></p>\n\n<p class=MsoNormal><font size=2 color=navy face=\"Comic Sans MS\"><span\nstyle='font-size:10.0pt;font-family:\"Comic Sans MS\";color:navy'><o:p>&nbsp;</o:p></span></font></p>\n\n<p class=MsoNormal><font size=2 color=navy face=\"Comic Sans MS\"><span\nstyle='font-size:10.0pt;font-family:\"Comic Sans MS\";color:navy'>M<o:p></o:p></span></font></p>\n\n<p class=MsoNormal><font size=2 color=navy face=\"Comic Sans MS\"><span\nstyle='font-size:10.0pt;font-family:\"Comic Sans MS\";color:navy'><o:p>&nbsp;</o:p></span></font></p>\n\n<p class=MsoNormal><em><i><font size=3 color=navy face=Papyrus><span\nstyle='font-size:12.0pt;font-family:Papyrus;color:navy'>Manuela E. St\u00f6tter</span></font></i></em><font\ncolor=navy><span style='color:navy'><o:p></o:p></span></font></p>\n\n<p class=MsoNormal><strong><b><font size=2 color=navy\nface=\"Copperplate Gothic Light\"><span style='font-size:10.0pt;font-family:\"Copperplate Gothic Light\";\ncolor:navy'>RELATED</span></font></b></strong><font color=navy><span\nstyle='color:navy'><o:p></o:p></span></font></p>\n\n<p class=MsoNormal><st1:Street w:st=\"on\"><st1:address w:st=\"on\"><em><i><font\n  size=2 color=navy face=Papyrus><span style='font-size:10.0pt;font-family:\n  Papyrus;color:navy'>60 Columbus Circle</span></font></i></em></st1:address></st1:Street><font\ncolor=navy><span style='color:navy'><o:p></o:p></span></font></p>\n\n<p class=MsoNormal><st1:place w:st=\"on\"><st1:City w:st=\"on\"><em><i><font\n  size=2 color=navy face=Papyrus><span style='font-size:10.0pt;font-family:\n  Papyrus;color:navy'>New York</span></font></i></em></st1:City><em><i><font\n size=2 color=navy face=Papyrus><span style='font-size:10.0pt;font-family:Papyrus;\n color:navy'>, <st1:State w:st=\"on\">NY</st1:State> <st1:PostalCode w:st=\"on\">10023</st1:PostalCode></span></font></i></em></st1:place><font\ncolor=navy><span style='color:navy'><o:p></o:p></span></font></p>\n\n<p class=MsoNormal><em><i><font size=2 color=navy face=Papyrus><span\nstyle='font-size:10.0pt;font-family:Papyrus;color:navy'>Tel: 212.801.3796</span></font></i></em><font\ncolor=navy><span style='color:navy'><o:p></o:p></span></font></p>\n\n<p cl