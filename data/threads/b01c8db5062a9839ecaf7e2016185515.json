[{"id":"03f79e0b8032d01e184364c268e630da","from":"craig","from_email":"craig@penumbramarine.com","to":"lvjet@aol.com","to_list":[{"name":"lvjet@aol.com","email":"lvjet@aol.com"}],"cc_list":[{"name":"J. Epstein","email":"jeeproject@yahoo.com"}],"subject":"Wast Treatment Plants","date":"2008-05-08T17:05:53.000Z","formatted_date":"May 8, 2008","formatted_time":"5:05 PM","body":"Larry,\n\n \n\nWe are selling Waste Treatment Plants that recycle 100% of the sewage to a\nre-usable state that exceeds the State of Florida\u2019s re-use standards.  The\nmarket is actually for ships, yachts and RV\u2019s although we are getting ready\nto put a system on a small island in the Bahamas. This made me think of\nJeffrey.  \n\n \n\nThe by-product can be used for everything from watering the grounds,\nlaundry, flushing toilets, etc, etc.  The system has been around for 15\nyears but it was not until recently, I talked them into going \u201cMarine\u201d.  We\nare now selling them like crazy for Cruise Ships, yachts, etc, since the\n\u201cGreen\u201d movement is growing.\n\n \n\nIn the water sample photo you can see the quality of water on the left that\nis presently being pumped overboard from yachts like Limitless.  The bottle\nin the middle of the photo shows what we do with that.  The one on the right\nis our final stage which exceeds all water standards for marine discharge\nnow, the new 2010 regulations and even the future.  FYI \u2013 the system on\nLimitless will be illegal in 1 \u00bd years when the new regulations are in\neffect, as will all other Type II MSD (Marine Sanitation Devices) units.\n\n \n\nWe are also having these systems approved as individual Sewage Treatment\nPlants for homes and developments since they exceed State regulations for\nnot only re-use, but with one additional step, we are exceeding the\ndrinkable water standards for Florida. This state, and California have the\nhighest standards of the country.\n\n \n\nCheck it out at www.DragonflyMarine.com <http://www.dragonflymarine.com/> .\nWe are still developing the site but you can see the Beta display.\n\n \n\nKindest regards,\n\n \n\nCraig Tafoya\n\n3778 SW 30th Ave\n\nFt. Lauderdale, FL 33312\n\n+1.954.791.9992 T\n\n+1.954.328.6203 C\n\n+1.954.791.9499 F\n\n <http://www.CraigTafoya.com> www.CraigTafoya.com\n\n <http://www.TafoyaYachts.com> www.TafoyaYachts.com \n\nwww.DragonflyMarine.com\n\n \n\nDistributor for:\n\n \n\nMarine Dragonfly\n\nZero Discharge Wastewater Systems\n\n \n\n Marine Finishes\n\n \n\n \n\n \n\n \n\n \n\n","body_html":"<html xmlns:v=\"urn:schemas-microsoft-com:vml\" xmlns:o=\"urn:schemas-microsoft-com:office:office\" xmlns:w=\"urn:schemas-microsoft-com:office:word\" xmlns:st1=\"urn:schemas-microsoft-com:office:smarttags\" xmlns=\"http://www.w3.org/TR/REC-html40\">\n\n<head>\n<meta http-equiv=Content-Type content=\"text/html; charset=iso-8859-1\">\n<meta name=Generator content=\"Microsoft Word 11 (filtered medium)\">\n<!--[if !mso]>\n<style>\nv\\:* {behavior:url(#default#VML);}\no\\:* {behavior:url(#default#VML);}\nw\\:* {behavior:url(#default#VML);}\n.shape {behavior:url(#default#VML);}\n</style>\n<![endif]--><o:SmartTagType\n namespaceuri=\"urn:schemas-microsoft-com:office:smarttags\" name=\"country-region\"/>\n<o:SmartTagType namespaceuri=\"urn:schemas-microsoft-com:office:smarttags\"\n name=\"PostalCode\"/>\n<o:SmartTagType namespaceuri=\"urn:schemas-microsoft-com:office:smarttags\"\n name=\"State\"/>\n<o:SmartTagType namespaceuri=\"urn:schemas-microsoft-com:office:smarttags\"\n name=\"City\"/>\n<o:SmartTagType namespaceuri=\"urn:schemas-microsoft-com:office:smarttags\"\n name=\"place\"/>\n<o:SmartTagType namespaceuri=\"urn:schemas-microsoft-com:office:smarttags\"\n name=\"Street\"/>\n<o:SmartTagType namespaceuri=\"urn:schemas-microsoft-com:office:smarttags\"\n name=\"address\"/>\n<!--[if !mso]>\n<style>\nst1\\:*{behavior:url(#default#ieooui) }\n</style>\n<![endif]-->\n<style>\n<!--\n /* Font Definitions */\n @font-face\n\t{font-family:\"Blac