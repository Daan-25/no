[{"id":"ab699ab19b72507ea9ed1a88d2ef92ad","from":"Armand AZOULAY","from_email":"armand_azoulay@artisticimages.fr","to":"jeeproject@yahoo.com","to_list":[{"name":"jeeproject@yahoo.com","email":"jeeproject@yahoo.com"}],"cc_list":[],"subject":"Armand Azoulay","date":"2007-11-06T18:03:09.000Z","formatted_date":"Nov 6, 2007","formatted_time":"6:03 PM","body":"Dear Jeffrey,\n\n \n\nI understand that you need much more time to take your decision to market and industrialize the fruit of our research.\n\n \n\nAs I explained you when we met in Paris, I funded my research works and I invested more than 18 millions euros including 8 millions this year, and I would need 4 millions euros to finish my developments and to be able to maintain my team of researchers; \n\n \n\nSo my proposal is as follows:\n\n \n\nI own three buildings in Foch area in Paris, having a total surface of 1,780 square meters, evaluated to an amount of 25 millions euros that I am ready to put in guarantee against a loan amounting to 4 millions euros, because this 4 millions euros would resolve the situation and would let you all the necessary time to take your decision to become a partner or not.\n\n \n\nVery truly yours,\n\n \n\nArmand Azoulay\n\n+ 33 6 22 52 07 01\n","body_html":"<!DOCTYPE HTML PUBLIC \"-//W3C//DTD HTML 4.0 Transitional//EN\">\n<HTML><HEAD>\n<META http-equiv=Content-Type content=\"text/html; charset=iso-8859-1\">\n<META content=\"MSHTML 6.00.6000.16544\" name=GENERATOR>\n<STYLE></STYLE>\n</HEAD>\n<BODY bgColor=#ffffff>\n<DIV><FONT face=Arial size=2>\n<P class=MsoNormal style=\"MARGIN: 0cm 0cm 0pt\"><SPAN lang=EN-GB \nstyle=\"mso-ansi-language: EN-GB\"><FONT size=3><FONT face=\"Times New Roman\">Dear \nJeffrey,<?xml:namespace prefix = o ns = \n\"urn:schemas-microsoft-com:office:office\" /><o:p></o:p></FONT></FONT></SPAN></P>\n<P class=MsoNormal style=\"MARGIN: 0cm 0cm 0pt\"><SPAN lang=EN-GB \nstyle=\"mso-ansi-language: EN-GB\"><o:p><FONT face=\"Times New Roman\" \nsize=3>&nbsp;</FONT></o:p